    },
    {
      "stage_id": "work_order",
      "from_node": "qianxuesen_repair_ticket_node",
      "to_node": "qianxuesen_work_order_node",
      "after_node": "qianxuesen_repair_ticket_node",
      "hook": "qianxuesen_work_order_route",
