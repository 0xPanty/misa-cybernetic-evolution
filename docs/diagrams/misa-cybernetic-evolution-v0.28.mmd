graph TD
  TITLE["Misa Cybernetic Evolution Layer v0.28<br/>measurement-first control loop for Hermes-style agents"]

  subgraph SRC["SIGNAL INTAKE - two real evidence lanes"]
    subgraph A_SRC["Lane A - Qianxuesen window distillation"]
      A0["Window bundle<br/>redacted transcript slices<br/>local refs only"]
      A1["Source ledger<br/>retrieval trace<br/>Hermes refs<br/>timestamps"]
      A2["Distillation template<br/>observation -> claim -> evidence<br/>counter-evidence / uncertainty<br/>route hint / replay requirement"]
      A3["Signal map<br/>memory | skill | case<br/>policy | damping"]
      A4["Replay synthesis<br/>candidate evidence packet<br/>source-backed"]
      A0 --> A1 --> A2 --> A3 --> A4
    end

    subgraph C_SRC["Lane B - Hermes runtime logs and model I/O"]
      C0["Runtime operation logs<br/>pre/post tool_call<br/>action identity folded"]
      C1["Action-history monitor<br/>failure-after-repeat<br/>query entropy"]
      C2["API boundary hooks<br/>pre/post api_request"]
      C3["Model I/O tap<br/>context bytes<br/>tool schema count<br/>hashes only"]
      C4["Measurement quality gate<br/>clean / input dirty / behavior loop<br/>compound / insufficient"]
      C5["Gate-of-gate bias monitor<br/>per-candidate skew<br/>emit-only"]
      C0 --> C1 --> C4
      C2 --> C3 --> C4 --> C5
    end
  end

  subgraph L0["L0 SENSOR CONTRACT - do not trust unnamed signals"]
    L0A["Schema lock<br/>record_kind + signal_origin required"]
    L0B["Redaction boundary<br/>no raw prompt / token / tool args in repo"]
    L0C["Authority split<br/>window evidence can seed candidates<br/>runtime telemetry stays observability"]
    L0A --> L0B --> L0C
  end

  subgraph L1["L1 EVIDENCE DISTILLATION - turn windows into controllable signals"]
    L1A["Controlled distillation<br/>source-backed lessons<br/>context entropy compressed"]
    L1B["Route vocabulary<br/>memory / skill / case<br/>policy / damping"]
    L1C["Candidate gates<br/>minimal L3<br/>preflight<br/>repair ticket"]
    L1A --> L1B --> L1C
  end

  subgraph L2["L2 CROSS-VALIDATION - check whether the measurement is trustworthy"]
    L2A["Behavior evidence<br/>is the agent looping?"]
    L2B["Input evidence<br/>is the prompt/case file polluted?"]
    L2C["Three-way check<br/>candidate result x action history x model I/O"]
    L2D["Gate verdict<br/>clean / input dirty / behavior loop<br/>compound / insufficient"]
    L2E["Boundary rule<br/>no clean measurement -> no candidate judgment"]
    L2A --> L2C
    L2B --> L2C --> L2D --> L2E
  end

  subgraph L3["L3 CONTROL ROUTING + FEEDBACK - runtime noise may become work, not truth"]
    L3A["Anomaly rule registry<br/>versioned deterministic rules"]
    L3B["Observability stream<br/>audit / SNR / diagnostics"]
    L3C["Work-order stream<br/>only registered boundary issues"]
    L3D["Variant + quality eval<br/>strategy fit<br/>replay value<br/>boundary safety"]
    L3E["L3 feedback reducer<br/>red / yellow / green pools<br/>semantic pressure"]
    L3F["Feedback targets<br/>tighten L1 source selection<br/>repair L2 gates<br/>seed better variants"]
    L3A --> L3B
    L3A --> L3C --> L3D --> L3E --> L3F
  end

  FB["NEXT-CYCLE FEEDBACK BUFFER<br/>feeds future source selection, gate repair, and variant seeds<br/>no direct winner authority"]

  subgraph L4["L4 DECISION BOUNDARY - safe drafts out, humans hold the actuator"]
    L4A["Tournament<br/>positive lift<br/>no safety regression"]
    L4B["Value proof<br/>local/synthetic discrimination<br/>current corpus only"]
    L4C["Human boundary<br/>approve / hold / reject"]
    L4D["Allowed outputs<br/>draft skill<br/>repair ticket<br/>work order"]
    L4A --> L4B --> L4C --> L4D
  end

  BLOCK["BLOCKED BY DEFAULT<br/>raw private content | memory writes | skill install | provider routes<br/>runtime blocking | public posts | VPS updates | runtime-log tournament"]

  TITLE --> A0
  TITLE --> C0
  TITLE --> C2
  A4 --> L0A
  C4 --> L0A
  C5 --> L0A
  L0C --> L1A
  L1C --> L2C
  A4 -. "candidate result evidence" .-> L2C
  C1 --> L2A
  C3 --> L2B
  L2E --> L3A
  L3F --> L4A
  L4D --> BLOCK

  C4 -. "measurement verdict only" .-> L2D
  L3B -. "audit only" .-> BLOCK
  L3C -. "repair queue only" .-> L4D
  L3F -. "feedback only, no winner authority" .-> FB

