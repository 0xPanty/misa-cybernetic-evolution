flowchart TB

  TITLE["<b>Misa Cybernetic Evolution Layer · v0.28</b><br/><i>Measurement-first control loop · Engineering Cybernetics for AI agents</i>"]

  %% =========================================================
  %% TOP: two evidence lanes (the only data-backed lanes)
  %% =========================================================
  subgraph LA["Lane A &nbsp;·&nbsp; Qianxuesen window distillation"]
    direction TB
    A1[/"Window bundle<br/><i>redacted slices · local refs</i>"/]
    A2["Source ledger<br/><i>retrieval trace · timestamps</i>"]
    A3["Distillation template<br/><i>obs → claim → evidence<br/>counter-evidence · uncertainty</i>"]
    A4["Signal map<br/><i>memory | skill | case<br/>policy | damping</i>"]
    A5["Replay synthesis<br/><i>candidate evidence packet</i>"]
    A1 --> A2 --> A3 --> A4 --> A5
  end

  subgraph LB["Lane B &nbsp;·&nbsp; Hermes runtime + model I/O"]
    direction TB
    B1[/"Runtime ops<br/><i>pre/post tool_call</i>"/]
    B2[/"API boundary hooks<br/><i>pre/post api_request</i>"/]
    B3["action_history_monitor<br/><i>failure-after-repeat<br/>query entropy</i>"]
    B4["model_io_tap<br/><i>context bytes · tool count<br/>hashes only · no raw</i>"]
    B1 --> B3
    B2 --> B4
  end

  %% =========================================================
  %% MIDDLE: the v0.28 punchline — measurement quality gate
  %% =========================================================
  subgraph GATE["★ &nbsp; v0.28 NEW &nbsp;·&nbsp; Measurement Quality Gate"]
    direction TB
    G1{{"measurement_quality_gate<br/>━━━━━━━━━━━━━━━━━━━━━<br/><b>clean</b> &nbsp;·&nbsp; suspect_input<br/>suspect_behavior &nbsp;·&nbsp; suspect_compound<br/><i>insufficient_evidence</i> (fails closed)"}}
    G2["gate-of-gate bias monitor<br/><i>per-candidate skew · emit-only</i>"]
    G1 --> G2
  end

  %% =========================================================
  %% BOTTOM: three disjoint output streams
  %% =========================================================
  subgraph OUT["Output streams &nbsp;·&nbsp; schema-locked disjoint"]
    direction LR
    O1["observability_stream<br/><i>emit-only diagnostics</i>"]
    O2["work_order_stream<br/><i>replay-required</i>"]
    O3["evolution_candidates<br/><i>tournament input</i>"]
  end

  %% =========================================================
  %% SIDE LEFT: Layer 0 schema + redaction (the safety wall)
  %% =========================================================
  subgraph L0["Layer 0 &nbsp;·&nbsp; Schema + Redaction Contract"]
    direction TB
    S1["record_kind + signal_origin locked"]
    S2["no raw prompt / token / tool body persists"]
    S3["5 canary strings · CI-blocking"]
  end

  %% =========================================================
  %% SIDE RIGHT: hard-blocked surfaces (the boundary claim)
  %% =========================================================
  BLOCK["⛔ &nbsp; BLOCKED BY DEFAULT<br/>━━━━━━━━━━━━━━━━━━━<br/>memory writes · skill install<br/>provider routes · runtime block<br/>public posts · VPS update<br/>agent self-review · auto-replay<br/>LLM-owned route or winner"]

  %% =========================================================
  %% Flows
  %% =========================================================
  TITLE --> LA
  TITLE --> LB

  A3 --> G1
  B3 --> G1
  B4 --> G1

  A5 --> O2
  A5 --> O3
  B3 -. "observability" .-> O1
  B4 -. "observability" .-> O1
  G2 -. "emit-only verdict" .-> O1

  L0 -. "enforces" .-> LA
  L0 -. "enforces" .-> LB
  L0 -. "enforces" .-> GATE

  OUT -. "cannot reach" .-> BLOCK
  G1 -. "cannot trigger" .-> BLOCK

  %% =========================================================
  %% Styling — clear visual hierarchy
  %% Main flow: cyan-blue family
  %% v0.28 gate: magenta (the focus)
  %% Constraints / boundary: gray-dashed
  %% Blocked: red
  %% Output: green
  %% =========================================================
  classDef title fill:#0b1326,stroke:#38bdf8,stroke-width:2px,color:#f1f5f9;

  classDef laneA fill:#0c1f3a,stroke:#3b82f6,color:#dbeafe;
  classDef laneB fill:#1f1431,stroke:#a78bfa,color:#ede9fe;

  classDef gateMain fill:#3b0d2e,stroke:#f43f5e,stroke-width:3px,color:#fce7f3;
  classDef gateSub fill:#2a0f24,stroke:#f9a8d4,color:#fbcfe8;

  classDef out fill:#0e2a1d,stroke:#22c55e,color:#dcfce7;

  classDef sch fill:#1a1d24,stroke:#94a3b8,color:#cbd5e1,stroke-dasharray:6 4;

  classDef blocked fill:#2a0b0b,stroke:#dc2626,stroke-width:2px,color:#fecaca;

  class TITLE title
  class A1,A2,A3,A4,A5 laneA
  class B1,B2,B3,B4 laneB
  class G1 gateMain
  class G2 gateSub
  class O1,O2,O3 out
  class S1,S2,S3 sch
  class BLOCK blocked
