graph TD
  TITLE["Misa Cybernetic Evolution Layer v0.28<br/>measurement-first control loop for Hermes-style agents"]

  subgraph SRC["SIGNAL INTAKE - two real evidence lanes"]
    subgraph A_SRC["Lane A - Qianxuesen window distillation"]
      A0["Redacted session windows<br/>local refs only"]
      A1["Source lineage<br/>retrieval trace<br/>Hermes refs"]
      A2["Distill + map<br/>segments -> signals"]
      A3["Replay synthesis<br/>primary evolution input"]
      A0 --> A1 --> A2 --> A3
    end

    subgraph C_SRC["Lane B - Hermes runtime logs and model I/O"]
      C0["Runtime operation logs<br/>pre/post tool_call"]
      C1["API boundary hooks<br/>pre/post api_request"]
      C2["Action-history monitor<br/>failure-after-repeat<br/>query entropy"]
      C3["Model I/O tap<br/>context bytes<br/>tool schema count<br/>hashes only"]
      C4["Measurement quality gate<br/>clean / input dirty / behavior loop<br/>compound / insufficient"]
      C5["Gate-of-gate bias monitor<br/>per-candidate skew<br/>emit-only"]
      C0 --> C2 --> C4
      C1 --> C3 --> C4 --> C5
    end
  end

  subgraph L0["L0 SENSOR CONTRACT - do not trust unnamed signals"]
    L0A["Schema lock<br/>record_kind + signal_origin required"]
    L0B["Redaction boundary<br/>no raw prompt / token / tool args in repo"]
    L0C["Two-lane split<br/>window evidence vs runtime observability"]
    L0A --> L0B --> L0C
  end

  subgraph L1["L1 EVIDENCE DISTILLATION - turn windows into controllable signals"]
    L1A["Window distiller<br/>compress context entropy"]
    L1B["Route vocabulary<br/>memory / skill / case<br/>policy / damping"]
    L1C["Candidate gates<br/>minimal L3<br/>preflight<br/>repair ticket"]
    L1A --> L1B --> L1C
  end

  subgraph L2["L2 MEASUREMENT VALIDITY - check whether the case file is clean"]
    L2A["Behavior evidence<br/>is the agent looping?"]
    L2B["Input evidence<br/>is the prompt/case file polluted?"]
    L2C["Gate verdict<br/>advisory-only in v0.28"]
    L2D["Boundary rule<br/>diagnosis cannot become tournament truth"]
    L2A --> L2C
    L2B --> L2C --> L2D
  end

  subgraph L3["L3 CONTROL ROUTING - runtime noise may become work, not truth"]
    L3A["Anomaly rule registry<br/>versioned deterministic rules"]
    L3B["Observability stream<br/>audit / SNR / diagnostics"]
    L3C["Work-order stream<br/>only registered boundary issues"]
    L3D["Variant + quality eval<br/>strategy fit<br/>replay value<br/>boundary safety"]
    L3A --> L3B
    L3A --> L3C --> L3D
  end

  subgraph L4["L4 DECISION BOUNDARY - safe drafts out, humans hold the actuator"]
    L4A["Tournament<br/>positive lift<br/>no safety regression"]
    L4B["Value proof<br/>local/synthetic discrimination<br/>current corpus only"]
    L4C["Human boundary<br/>approve / hold / reject"]
    L4D["Allowed outputs<br/>draft skill<br/>repair ticket<br/>work order"]
    L4A --> L4B --> L4C --> L4D
  end

  BLOCK["BLOCKED BY DEFAULT<br/>raw private content | memory writes | skill install | provider routes<br/>runtime blocking | public posts | VPS updates | runtime-log tournament"]

  TITLE --> A0
  TITLE --> C0
  TITLE --> C1
  A3 --> L0A
  C4 --> L0A
  C5 --> L0A
  L0C --> L1A
  L1C --> L2A
  C2 --> L2A
  C3 --> L2B
  L2D --> L3A
  L3D --> L4A
  L4D --> BLOCK

  C4 -. "measurement verdict only" .-> L2C
  L3B -. "audit only" .-> BLOCK
  L3C -. "repair queue only" .-> L4D

  classDef title fill:#0f172a,stroke:#38bdf8,color:#f8fafc;
  classDef source fill:#082f49,stroke:#38bdf8,color:#e0f2fe;
  classDef runtime fill:#3b1d0f,stroke:#fb923c,color:#ffedd5;
  classDef contract fill:#13321f,stroke:#22c55e,color:#dcfce7;
  classDef distill fill:#123047,stroke:#06b6d4,color:#ecfeff;
  classDef measure fill:#3a1f5d,stroke:#c084fc,color:#f3e8ff;
  classDef route fill:#3f2a08,stroke:#f59e0b,color:#fef3c7;
  classDef decision fill:#451a03,stroke:#f97316,color:#ffedd5;
  classDef block fill:#111827,stroke:#ef4444,color:#fee2e2;

  class TITLE title;
  class A0,A1,A2,A3 source;
  class C0,C1,C2,C3,C4,C5 runtime;
  class L0A,L0B,L0C contract;
  class L1A,L1B,L1C distill;
  class L2A,L2B,L2C,L2D measure;
  class L3A,L3B,L3C,L3D route;
  class L4A,L4B,L4C,L4D decision;
  class BLOCK block;
