{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/work_order_variants.schema.json",
  "title": "WorkOrderVariants",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "ok",
    "created_at",
    "seed",
    "mutation_policy",
    "model_role_policy",
    "source_routing_summary",
    "summary",
    "work_order_results",
    "safety",
    "warnings"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "misa.work_order_variants.v1" },
    "mode": { "type": "string", "const": "work-order-variants" },
    "ok": { "type": "boolean", "const": true },
    "created_at": { "type": "string", "format": "date-time" },
    "seed": { "type": "string" },
    "mutation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "population_size",
        "max_rounds",
        "deterministic_seeded_randomness",
        "strategies",
        "llm_policy"
      ],
      "properties": {
        "population_size": { "type": "integer", "minimum": 3 },
        "max_rounds": { "type": "integer", "const": 1 },
        "deterministic_seeded_randomness": { "type": "boolean", "const": true },
        "strategies": { "$ref": "#/$defs/string_array" },
        "llm_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "default_call_policy",
            "intervention_rule",
            "allowed_role",
            "mutation_crossover_policy",
            "route_or_winner_authority"
          ],
          "properties": {
            "default_call_policy": { "type": "string", "const": "do_not_call" },
            "intervention_rule": { "type": "string" },
            "allowed_role": { "type": "string", "const": "critique_only" },
            "mutation_crossover_policy": { "$ref": "#/$defs/mutation_crossover_policy" },
            "route_or_winner_authority": { "type": "boolean", "const": false }
          }
        }
      }
    },
    "model_role_policy": { "$ref": "#/$defs/model_role_separation" },
    "source_routing_summary": { "type": "object", "additionalProperties": true },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_order_count",
        "variant_count",
        "winner_count",
        "rejected_variant_count",
        "llm_critique_recommended_count",
        "llm_mutation_crossover_review_worthy_count",
        "primary_agent_inline_review_count",
        "separate_llm_call_required_count",
        "llm_api_calls",
        "external_api_calls",
        "by_winner_strategy"
      ],
      "properties": {
        "work_order_count": { "type": "integer", "minimum": 0 },
        "variant_count": { "type": "integer", "minimum": 0 },
        "winner_count": { "type": "integer", "minimum": 0 },
        "rejected_variant_count": { "type": "integer", "minimum": 0 },
        "llm_critique_recommended_count": { "type": "integer", "minimum": 0 },
        "llm_mutation_crossover_review_worthy_count": { "type": "integer", "minimum": 0 },
        "primary_agent_inline_review_count": { "type": "integer", "minimum": 0 },
        "separate_llm_call_required_count": { "type": "integer", "const": 0 },
        "llm_api_calls": { "type": "integer", "const": 0 },
        "external_api_calls": { "type": "integer", "const": 0 },
        "by_winner_strategy": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      }
    },
    "work_order_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/work_order_result" }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_authority",
        "executes_work_orders",
        "writes_persistent_memory",
        "installs_skills",
        "durable_or_public_effect_allowed",
        "changes_route",
        "changes_winner_authority",
        "llm_api_calls",
        "external_api_calls"
      ],
      "properties": {
        "production_authority": { "type": "boolean", "const": false },
        "executes_work_orders": { "type": "boolean", "const": false },
        "writes_persistent_memory": { "type": "boolean", "const": false },
        "installs_skills": { "type": "boolean", "const": false },
        "durable_or_public_effect_allowed": { "type": "boolean", "const": false },
        "changes_route": { "type": "boolean", "const": false },
        "changes_winner_authority": { "type": "boolean", "const": false },
        "llm_api_calls": { "type": "integer", "const": 0 },
        "external_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "warnings": { "$ref": "#/$defs/string_array" },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_dir", "json_path", "markdown_path"],
      "properties": {
        "output_dir": { "type": "string" },
        "json_path": { "type": "string" },
        "markdown_path": { "type": "string" }
      }
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mutation_crossover_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "default_call_policy",
        "activation_rule",
        "allowed_role_if_enabled",
        "route_or_winner_authority",
        "llm_api_calls"
      ],
      "properties": {
        "enabled": { "type": "boolean", "const": false },
        "default_call_policy": { "type": "string", "const": "do_not_call" },
        "activation_rule": { "type": "string" },
        "allowed_role_if_enabled": { "type": "string", "const": "candidate_suggester_only" },
        "route_or_winner_authority": { "type": "boolean", "const": false },
        "llm_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "model_role_separation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "deterministic_controller",
        "evolution_model",
        "task_model"
      ],
      "properties": {
        "policy": { "type": "string", "const": "deterministic_controller_owns_route_score_and_selection" },
        "deterministic_controller": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owns_route", "owns_scoring", "owns_selection", "owns_safety_gate"],
          "properties": {
            "owns_route": { "type": "boolean", "const": true },
            "owns_scoring": { "type": "boolean", "const": true },
            "owns_selection": { "type": "boolean", "const": true },
            "owns_safety_gate": { "type": "boolean", "const": true }
          }
        },
        "evolution_model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "role",
            "default_call_policy",
            "can_execute",
            "can_change_route",
            "can_change_winner",
            "can_write_memory"
          ],
          "properties": {
            "role": { "type": "string", "const": "optional_candidate_critic_or_mutation_crossover_suggester" },
            "default_call_policy": { "type": "string", "const": "do_not_call" },
            "can_execute": { "type": "boolean", "const": false },
            "can_change_route": { "type": "boolean", "const": false },
            "can_change_winner": { "type": "boolean", "const": false },
            "can_write_memory": { "type": "boolean", "const": false }
          }
        },
        "task_model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "role",
            "called_by_variant_layer",
            "can_self_select_candidate",
            "can_bypass_acceptance_or_forbidden_scope"
          ],
          "properties": {
            "role": { "type": "string", "const": "approved_work_order_executor_after_handoff" },
            "called_by_variant_layer": { "type": "boolean", "const": false },
            "can_self_select_candidate": { "type": "boolean", "const": false },
            "can_bypass_acceptance_or_forbidden_scope": { "type": "boolean", "const": false }
          }
        }
      }
    },
    "work_order_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_order_id",
        "title",
        "category",
        "severity",
        "risk_level",
        "source",
        "candidate_value_score",
        "variants",
        "winner",
        "loser_ledger",
        "llm_review_gate",
        "llm_mutation_crossover_gate",
        "model_role_separation"
      ],
      "properties": {
        "work_order_id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string" },
        "risk_level": { "type": "string" },
        "source": { "type": "object", "additionalProperties": true },
        "candidate_value_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "variants": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/variant" }
        },
        "winner": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "variant_id",
            "strategy",
            "composite_score",
            "recommended_surface",
            "execution_allowed",
            "publication_allowed",
            "rationale"
          ],
          "properties": {
            "variant_id": { "type": "string" },
            "strategy": { "type": "string" },
            "composite_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "recommended_surface": { "type": "string", "const": "work_order_draft_only" },
            "execution_allowed": { "type": "boolean", "const": false },
            "publication_allowed": { "type": "boolean", "const": false },
            "rationale": { "type": "string" }
          }
        },
        "loser_ledger": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["variant_id", "strategy", "status", "reason", "retained_as"],
            "properties": {
              "variant_id": { "type": "string" },
              "strategy": { "type": "string" },
              "status": { "type": "string", "enum": ["loser", "rejected"] },
              "reason": { "type": "string" },
              "retained_as": { "type": "string" }
            }
          }
        },
        "llm_review_gate": { "$ref": "#/$defs/llm_review_gate" },
        "llm_mutation_crossover_gate": { "$ref": "#/$defs/llm_mutation_crossover_gate" },
        "model_role_separation": { "$ref": "#/$defs/model_role_separation" }
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "variant_id",
        "strategy",
        "mutation_kind",
        "source_work_order_id",
        "title",
        "summary",
        "proposed_task_shape",
        "acceptance_criteria",
        "verification_focus",
        "forbidden_scope",
        "requested_operations",
        "safety",
        "scores",
        "constraints"
      ],
      "properties": {
        "variant_id": { "type": "string" },
        "strategy": { "type": "string" },
        "mutation_kind": { "type": "string" },
        "source_work_order_id": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "proposed_task_shape": {
          "type": "object",
          "additionalProperties": false,
          "required": ["keep", "add_or_emphasize", "stop_condition"],
          "properties": {
            "keep": { "$ref": "#/$defs/string_array" },
            "add_or_emphasize": { "$ref": "#/$defs/string_array" },
            "stop_condition": { "type": "string" }
          }
        },
        "acceptance_criteria": { "$ref": "#/$defs/string_array" },
        "verification_focus": { "type": "string" },
        "forbidden_scope": { "$ref": "#/$defs/string_array" },
        "requested_operations": { "$ref": "#/$defs/string_array" },
        "safety": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "production_authority",
            "durable_or_public_effect_allowed",
            "writes_persistent_memory",
            "installs_skills",
            "calls_llm",
            "calls_external_api"
          ],
          "properties": {
            "production_authority": { "type": "boolean", "const": false },
            "durable_or_public_effect_allowed": { "type": "boolean", "const": false },
            "writes_persistent_memory": { "type": "boolean", "const": false },
            "installs_skills": { "type": "boolean", "const": false },
            "calls_llm": { "type": "boolean", "const": false },
            "calls_external_api": { "type": "boolean", "const": false }
          }
        },
        "scores": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "value",
            "evidence",
            "safety",
            "clarity",
            "strategy_fit",
            "qianxuesen_alignment",
            "novelty",
            "complexity_penalty",
            "deterministic_jitter",
            "composite"
          ],
          "properties": {
            "value": { "type": "number", "minimum": 0, "maximum": 1 },
            "evidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "safety": { "type": "number", "minimum": 0, "maximum": 1 },
            "clarity": { "type": "number", "minimum": 0, "maximum": 1 },
            "strategy_fit": { "type": "number", "minimum": 0, "maximum": 1 },
            "qianxuesen_alignment": { "type": "number", "minimum": 0, "maximum": 1 },
            "novelty": { "type": "number", "minimum": 0, "maximum": 1 },
            "complexity_penalty": { "type": "number", "minimum": 0, "maximum": 1 },
            "deterministic_jitter": { "type": "number", "minimum": 0, "maximum": 1 },
            "composite": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hard_gate_passed",
            "route_preserved",
            "source_trace_preserved",
            "no_live_effects",
            "no_llm_call",
            "no_direct_execution",
            "violations"
          ],
          "properties": {
            "hard_gate_passed": { "type": "boolean" },
            "route_preserved": { "type": "boolean", "const": true },
            "source_trace_preserved": { "type": "boolean", "const": true },
            "no_live_effects": { "type": "boolean", "const": true },
            "no_llm_call": { "type": "boolean", "const": true },
            "no_direct_execution": { "type": "boolean", "const": true },
            "violations": { "$ref": "#/$defs/string_array" }
          }
        }
      }
    },
    "llm_review_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommended",
        "level",
        "expected_value",
        "reason",
        "trigger_signals",
        "call_policy",
        "should_change_winner",
        "allowed_outputs",
        "forbidden_outputs",
        "llm_api_calls"
      ],
      "properties": {
        "recommended": { "type": "boolean" },
        "level": { "type": "string", "enum": ["none", "medium", "high"] },
        "expected_value": { "type": "string", "enum": ["none", "diagnostic_note_only", "critique_only"] },
        "reason": { "type": "string" },
        "trigger_signals": { "$ref": "#/$defs/string_array" },
        "call_policy": { "type": "string", "enum": ["do_not_call", "call_when_auto_enabled"] },
        "should_change_winner": { "type": "boolean", "const": false },
        "allowed_outputs": { "$ref": "#/$defs/string_array" },
        "forbidden_outputs": { "$ref": "#/$defs/string_array" },
        "llm_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "llm_mutation_crossover_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "candidate_value",
        "level",
        "intervention_mode",
        "call_policy",
        "activation_required",
        "separate_llm_call_required",
        "primary_agent_review_required",
        "external_model_call_policy",
        "reason",
        "trigger_signals",
        "allowed_outputs_if_enabled",
        "forbidden_outputs",
        "mutation_candidate_allowed",
        "crossover_candidate_allowed",
        "should_change_winner",
        "route_or_winner_authority",
        "llm_api_calls"
      ],
      "properties": {
        "enabled": { "type": "boolean", "const": false },
        "candidate_value": { "type": "string", "enum": ["none", "diagnostic_only", "review_worthy"] },
        "level": { "type": "string", "enum": ["none", "medium", "high"] },
        "intervention_mode": { "type": "string", "enum": ["none", "primary_agent_diagnostic_note", "primary_agent_inline_review"] },
        "call_policy": { "type": "string", "enum": ["do_not_call", "primary_agent_inline_review"] },
        "activation_required": { "type": "string", "enum": ["explicit_manual_enable_after_holdout_lift", "included_in_current_primary_agent_context"] },
        "separate_llm_call_required": { "type": "boolean", "const": false },
        "primary_agent_review_required": { "type": "boolean" },
        "external_model_call_policy": { "type": "string", "const": "requires_explicit_enable" },
        "reason": { "type": "string" },
        "trigger_signals": { "$ref": "#/$defs/string_array" },
        "allowed_outputs_if_enabled": { "$ref": "#/$defs/string_array" },
        "forbidden_outputs": { "$ref": "#/$defs/string_array" },
        "mutation_candidate_allowed": { "type": "boolean", "const": false },
        "crossover_candidate_allowed": { "type": "boolean", "const": false },
        "should_change_winner": { "type": "boolean", "const": false },
        "route_or_winner_authority": { "type": "boolean", "const": false },
        "llm_api_calls": { "type": "integer", "const": 0 }
      }
    }
  }
}
