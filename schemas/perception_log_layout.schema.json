{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/perception_log_layout.schema.json",
  "title": "PerceptionLogLayout",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "layout_id",
    "mode",
    "generated_at",
    "root_dir",
    "shadow_only",
    "directories",
    "flow_edges",
    "rules",
    "summary",
    "safety"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "misa.perception_log_layout.v1" },
    "layout_id": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "const": "shadow-perception-log-layout" },
    "generated_at": { "type": "string", "format": "date-time" },
    "root_dir": { "type": "string", "minLength": 1 },
    "shadow_only": { "type": "boolean", "const": true },
    "initialized": { "type": "boolean" },
    "created_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "directories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/directory" }
    },
    "flow_edges": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/flow_edge" }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_logs_are_not_learning_material",
        "redaction_required_before_perception",
        "redacted_sources_are_perception_input",
        "perception_digest_is_hint_only",
        "signal_ledger_updates_are_proposals_only",
        "qianxuesen_keeps_route_authority",
        "production_authority"
      ],
      "properties": {
        "raw_logs_are_not_learning_material": { "type": "boolean", "const": true },
        "redaction_required_before_perception": { "type": "boolean", "const": true },
        "redacted_sources_are_perception_input": { "type": "boolean", "const": true },
        "perception_digest_is_hint_only": { "type": "boolean", "const": true },
        "signal_ledger_updates_are_proposals_only": { "type": "boolean", "const": true },
        "qianxuesen_keeps_route_authority": { "type": "boolean", "const": true },
        "production_authority": { "type": "boolean", "const": false }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directory_count",
        "flow_edge_count",
        "perception_readable_count",
        "handoff_directory_count",
        "archive_directory_count",
        "llm_api_calls",
        "external_api_calls",
        "production_authority"
      ],
      "properties": {
        "directory_count": { "type": "integer", "minimum": 0 },
        "flow_edge_count": { "type": "integer", "minimum": 0 },
        "perception_readable_count": { "type": "integer", "minimum": 0 },
        "handoff_directory_count": { "type": "integer", "minimum": 0 },
        "archive_directory_count": { "type": "integer", "minimum": 0 },
        "llm_api_calls": { "type": "integer", "const": 0 },
        "external_api_calls": { "type": "integer", "const": 0 },
        "production_authority": { "type": "boolean", "const": false }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_authority",
        "writes_persistent_memory",
        "writes_zilliz",
        "creates_embeddings",
        "installs_skills",
        "publication_allowed",
        "changes_route",
        "changes_winner",
        "starts_services",
        "llm_api_calls",
        "external_api_calls"
      ],
      "properties": {
        "production_authority": { "type": "boolean", "const": false },
        "writes_persistent_memory": { "type": "boolean", "const": false },
        "writes_zilliz": { "type": "boolean", "const": false },
        "creates_embeddings": { "type": "boolean", "const": false },
        "installs_skills": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "changes_route": { "type": "boolean", "const": false },
        "changes_winner": { "type": "boolean", "const": false },
        "starts_services": { "type": "boolean", "const": false },
        "llm_api_calls": { "type": "integer", "const": 0 },
        "external_api_calls": { "type": "integer", "const": 0 }
      }
    }
  },
  "$defs": {
    "directory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "rel_path",
        "layer",
        "purpose",
        "readable_by_perception",
        "allowed_contents",
        "blocked_contents",
        "handoff_target",
        "path",
        "create_on_init",
        "authority"
      ],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "rel_path": { "type": "string", "minLength": 1 },
        "layer": {
          "type": "string",
          "enum": ["runtime_logs", "perception", "handoff", "archive"]
        },
        "purpose": { "type": "string", "minLength": 1 },
        "readable_by_perception": { "type": "boolean" },
        "allowed_contents": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "blocked_contents": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "handoff_target": {
          "type": "string",
          "enum": ["none", "qianxuesen", "repair_ticket", "work_order", "mixed"]
        },
        "path": { "type": "string", "minLength": 1 },
        "create_on_init": { "type": "boolean", "const": true },
        "authority": { "type": "string", "const": "layout_contract_only" }
      }
    },
    "flow_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "gate", "authority"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "gate": { "type": "string", "minLength": 1 },
        "authority": { "type": "string", "const": "layout_contract_only" }
      }
    }
  }
}
