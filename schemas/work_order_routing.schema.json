{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/work_order_routing.schema.json",
  "title": "WorkOrderRouting",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "ok",
    "created_at",
    "receiver_slots",
    "routing_policy",
    "summary",
    "work_orders",
    "safety",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "misa.work_order_routing.v1"
    },
    "mode": {
      "type": "string",
      "const": "work-order-routing"
    },
    "ok": { "type": "boolean", "const": true },
    "created_at": { "type": "string", "format": "date-time" },
    "receiver_slots": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/receiver_slot" },
      "minProperties": 1
    },
    "routing_policy": { "$ref": "#/$defs/routing_policy" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_order_count",
        "by_category",
        "by_suggested_executor",
        "requires_user_confirmation_count",
        "auto_executable_count",
        "escalation_available_count",
        "stronger_model_recommended_count"
      ],
      "properties": {
        "work_order_count": { "type": "integer", "minimum": 0 },
        "by_category": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "by_suggested_executor": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "requires_user_confirmation_count": { "type": "integer", "minimum": 0 },
        "auto_executable_count": { "type": "integer", "minimum": 0 },
        "escalation_available_count": { "type": "integer", "minimum": 0 },
        "stronger_model_recommended_count": { "type": "integer", "minimum": 0 }
      }
    },
    "work_orders": {
      "type": "array",
      "items": { "$ref": "#/$defs/work_order" }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auto_execute_allowed",
        "durable_or_public_effect_allowed",
        "primary_agent_must_report_first",
        "user_may_escalate_to_stronger_model",
        "traceability_required"
      ],
      "properties": {
        "auto_execute_allowed": { "type": "boolean" },
        "durable_or_public_effect_allowed": { "type": "boolean", "const": false },
        "primary_agent_must_report_first": { "type": "boolean" },
        "user_may_escalate_to_stronger_model": { "type": "boolean", "const": true },
        "traceability_required": { "type": "boolean", "const": true }
      }
    },
    "warnings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_dir", "json_path", "markdown_path"],
      "properties": {
        "output_dir": { "type": "string" },
        "json_path": { "type": "string" },
        "markdown_path": { "type": "string" }
      }
    }
  },
  "$defs": {
    "receiver_slot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "role"],
      "properties": {
        "label": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "routing_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "auto_execute_allowed",
        "max_auto_severity",
        "auto_execute_categories",
        "primary_agent_report_first",
        "stronger_model_policy",
        "durable_or_public_effect_policy"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "report_only",
            "ask_before_execution",
            "agent_autonomous_low_risk",
            "agent_autonomous_within_scope"
          ]
        },
        "auto_execute_allowed": { "type": "boolean" },
        "max_auto_severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
        "auto_execute_categories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["*", "engineering_repair", "operator_quality"]
          }
        },
        "primary_agent_report_first": { "type": "boolean" },
        "stronger_model_policy": { "type": "string" },
        "durable_or_public_effect_policy": { "type": "string", "const": "human_owner_required" }
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": { "type": "string" },
        "id": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "receiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receiver_type", "receiver_label", "delivery_policy", "reason"],
      "properties": {
        "receiver_type": { "type": "string", "enum": ["primary_agent"] },
        "receiver_label": { "type": "string" },
        "delivery_policy": {
          "type": "string",
          "enum": [
            "report_to_user_before_execution",
            "report_only_wait_for_user",
            "notify_then_execute_within_scope"
          ]
        },
        "reason": { "type": "string" }
      }
    },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executor_type", "label", "reason"],
      "properties": {
        "executor_type": {
          "type": "string",
          "enum": [
            "primary_agent",
            "persona_operator_agent",
            "specialized_engineering_agent",
            "stronger_model",
            "human_owner"
          ]
        },
        "label": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "task_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "complex_enough",
        "valuable_enough",
        "doable_enough",
        "error_discovery_cost",
        "verdict",
        "reasons"
      ],
      "properties": {
        "complex_enough": { "type": "boolean" },
        "valuable_enough": { "type": "boolean" },
        "doable_enough": { "type": "boolean" },
        "error_discovery_cost": { "type": "string", "enum": ["low", "medium", "high"] },
        "verdict": {
          "type": "string",
          "enum": [
            "ask_user_then_delegate",
            "human_owner_review_before_delegate",
            "hold_or_observe"
          ]
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence",
        "reproduction_commands",
        "acceptance_criteria",
        "editable_scope",
        "forbidden_scope",
        "audit_required",
        "rollback_required",
        "source_refs_required"
      ],
      "properties": {
        "evidence": { "type": "object", "additionalProperties": true },
        "reproduction_commands": { "type": "array", "items": { "type": "string" } },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "editable_scope": { "type": "array", "items": { "type": "string" } },
        "forbidden_scope": { "type": "array", "items": { "type": "string" } },
        "audit_required": { "type": "boolean", "const": true },
        "rollback_required": { "type": "boolean" },
        "source_refs_required": { "type": "boolean", "const": true }
      }
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requires_user_confirmation",
        "auto_execute_allowed",
        "self_evolution_allowed",
        "durable_or_public_effect_allowed",
        "default_next_step"
      ],
      "properties": {
        "requires_user_confirmation": { "type": "boolean" },
        "auto_execute_allowed": { "type": "boolean" },
        "self_evolution_allowed": { "type": "boolean" },
        "durable_or_public_effect_allowed": { "type": "boolean", "const": false },
        "default_next_step": {
          "type": "string",
          "enum": ["ask_user_to_choose_executor", "explain_and_hold", "execute_within_scope", "report_only_wait"]
        }
      }
    },
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "recommended_when",
        "stronger_model_slots",
        "user_can_decline_execution"
      ],
      "properties": {
        "allowed": { "type": "boolean" },
        "recommended_when": { "type": "string" },
        "stronger_model_slots": { "type": "array", "items": { "type": "string" } },
        "user_can_decline_execution": { "type": "boolean", "const": true }
      }
    },
    "model_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_model_fit",
        "stronger_model_recommended",
        "reason",
        "stronger_model_slots",
        "user_can_override"
      ],
      "properties": {
        "current_model_fit": {
          "type": "string",
          "enum": ["suitable_for_first_pass", "use_for_intake_or_small_patch_only"]
        },
        "stronger_model_recommended": { "type": "boolean" },
        "reason": { "type": "string" },
        "stronger_model_slots": { "type": "array", "items": { "type": "string" } },
        "user_can_override": { "type": "boolean", "const": true }
      }
    },
    "work_order": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_order_id",
        "title",
        "category",
        "severity",
        "risk_level",
        "status",
        "source",
        "summary",
        "source_refs",
        "delivery",
        "suggested_executor",
        "task_gate",
        "traceability",
        "execution_policy",
        "escalation",
        "model_handoff",
        "user_prompt"
      ],
      "properties": {
        "work_order_id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["engineering_repair", "operator_quality"] },
        "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
        "risk_level": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
        "status": { "type": "string", "const": "pending_user_choice" },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source_type", "source_id", "source_kind"],
          "properties": {
            "source_type": { "type": "string" },
            "source_id": { "type": ["string", "null"] },
            "source_kind": { "type": "string" }
          }
        },
        "summary": { "type": "string" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source_ref" }
        },
        "delivery": { "$ref": "#/$defs/receiver" },
        "suggested_executor": { "$ref": "#/$defs/executor" },
        "task_gate": { "$ref": "#/$defs/task_gate" },
        "traceability": { "$ref": "#/$defs/traceability" },
        "execution_policy": { "$ref": "#/$defs/execution_policy" },
        "escalation": { "$ref": "#/$defs/escalation" },
        "model_handoff": { "$ref": "#/$defs/model_handoff" },
        "user_prompt": { "type": "string" }
      }
    }
  }
}
