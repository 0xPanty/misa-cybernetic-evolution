{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/learning_item.schema.json",
  "title": "LearningItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "item_id",
    "kind",
    "source_events",
    "evidence_count",
    "confidence",
    "candidate_action",
    "status",
    "created_at"
  ],
  "properties": {
    "item_id": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["memory", "skill", "case", "policy", "ignore"]
    },
    "source_events": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_count": { "type": "integer", "minimum": 0 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "candidate_action": {
      "type": "string",
      "enum": ["create", "improve", "merge", "deprecate", "skip"]
    },
    "affected_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verification_plan": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rollback_plan": { "type": "string" },
    "owner": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "verified", "approved", "published", "rejected", "rolled_back"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
