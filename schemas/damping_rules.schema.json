{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/damping_rules.schema.json",
  "title": "DampingRules",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ruleset_id",
    "version",
    "promotion_thresholds",
    "cooldown_policy",
    "high_risk_actuators",
    "controller_conflict",
    "created_at"
  ],
  "properties": {
    "ruleset_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "promotion_thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "draft_after_events",
        "skill_candidate_after_successes",
        "case_candidate_after_failures",
        "policy_requires_approval",
        "high_risk_requires_contract"
      ],
      "properties": {
        "draft_after_events": { "type": "integer", "minimum": 1 },
        "skill_candidate_after_successes": { "type": "integer", "minimum": 3 },
        "case_candidate_after_failures": { "type": "integer", "minimum": 2 },
        "policy_requires_approval": { "type": "boolean", "const": true },
        "high_risk_requires_contract": { "type": "boolean", "const": true }
      }
    },
    "cooldown_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifier_failures",
        "same_mode_failure_window",
        "cooldown_duration",
        "escalation"
      ],
      "properties": {
        "verifier_failures": { "type": "integer", "minimum": 2 },
        "same_mode_failure_window": { "type": "string", "minLength": 1 },
        "cooldown_duration": { "type": "string", "minLength": 1 },
        "escalation": { "type": "string", "minLength": 1 }
      }
    },
    "high_risk_actuators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "public_posting",
          "provider_route",
          "session_mechanics",
          "background_timer",
          "persistent_deletion",
          "persistent_memory_write",
          "security_policy"
        ]
      }
    },
    "controller_conflict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_writer_required",
        "advisory_only_when_conflict"
      ],
      "properties": {
        "primary_writer_required": { "type": "boolean", "const": true },
        "advisory_only_when_conflict": { "type": "boolean", "const": true }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
