{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/evolution_tournament_gate.schema.json",
  "title": "EvolutionTournamentGateReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "ok",
    "created_at",
    "source",
    "algorithm_adaptation",
    "tournament_policy",
    "summary",
    "tournaments",
    "winner_queue",
    "rejected_variant_ledger",
    "experience_ledger",
    "control_boundary",
    "safety",
    "quality_assessment",
    "judge_escalation",
    "judge",
    "quality_comparison",
    "warnings",
    "violations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "misa.evolution_tournament_gate.v1"
    },
    "mode": {
      "type": "string",
      "const": "evolution-tournament-gate"
    },
    "ok": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preflight_mode",
        "source_kind",
        "source_dir",
        "vps_raw_dir",
        "optimization_candidate_count",
        "report_queue_count",
        "tournament_candidate_count"
      ],
      "properties": {
        "preflight_mode": { "type": "string", "minLength": 1 },
        "source_kind": { "type": "string", "minLength": 1 },
        "source_dir": { "type": ["string", "null"] },
        "vps_raw_dir": { "type": ["string", "null"] },
        "optimization_candidate_count": { "type": "integer", "minimum": 0 },
        "report_queue_count": { "type": "integer", "minimum": 0 },
        "tournament_candidate_count": { "type": "integer", "minimum": 0 }
      }
    },
    "algorithm_adaptation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "inspected_commit", "borrowed", "rejected"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "inspected_commit": { "type": "string", "minLength": 7 },
        "borrowed": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "rejected": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "tournament_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_owner",
        "candidate_generation",
        "scorer",
        "max_variants_per_candidate",
        "winner_surface",
        "loser_policy",
        "production_effect"
      ],
      "properties": {
        "route_owner": { "type": "string", "const": "qianxuesen" },
        "candidate_generation": { "type": "string", "const": "multi_variant_local" },
        "scorer": { "type": "string", "const": "deterministic_proxy_v1" },
        "max_variants_per_candidate": { "type": "integer", "minimum": 3 },
        "winner_surface": { "type": "string", "const": "draft_recommendation_only" },
        "loser_policy": { "type": "string", "minLength": 1 },
        "production_effect": { "type": "string", "const": "blocked" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tournament_count",
        "variant_count",
        "winner_count",
        "rejected_variant_count",
        "experience_ledger_count",
        "route_counts",
        "production_authority"
      ],
      "properties": {
        "tournament_count": { "type": "integer", "minimum": 0 },
        "variant_count": { "type": "integer", "minimum": 0 },
        "winner_count": { "type": "integer", "minimum": 0 },
        "rejected_variant_count": { "type": "integer", "minimum": 0 },
        "experience_ledger_count": { "type": "integer", "minimum": 0 },
        "route_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "production_authority": { "type": "boolean", "const": false }
      }
    },
    "tournaments": {
      "type": "array",
      "items": { "$ref": "#/$defs/tournament" }
    },
    "winner_queue": {
      "type": "array",
      "items": { "$ref": "#/$defs/winner" }
    },
    "rejected_variant_ledger": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["variant_id", "strategy", "violations", "blocked_requests", "retained_as"],
        "properties": {
          "variant_id": { "type": "string", "minLength": 1 },
          "strategy": { "type": "string", "minLength": 1 },
          "violations": {
            "type": "array",
            "items": { "type": "string" }
          },
          "blocked_requests": {
            "type": "array",
            "items": { "type": "string" }
          },
          "retained_as": { "type": "string", "minLength": 1 }
        }
      }
    },
    "experience_ledger": {
      "type": "array",
      "items": { "$ref": "#/$defs/experience_ledger_entry" }
    },
    "control_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "optimizer_role",
        "route_owner",
        "route_implementation",
        "llm_route_decision_allowed",
        "automatic_promotion_allowed",
        "promotion_surface"
      ],
      "properties": {
        "optimizer_role": { "type": "string", "const": "candidate_layer_only" },
        "route_owner": { "type": "string", "const": "qianxuesen" },
        "route_implementation": { "type": "string", "minLength": 1 },
        "llm_route_decision_allowed": { "type": "boolean", "const": false },
        "automatic_promotion_allowed": { "type": "boolean", "const": false },
        "promotion_surface": { "type": "string", "const": "none" }
      }
    },
    "safety": { "$ref": "#/$defs/safety" },
    "quality_assessment": { "$ref": "#/$defs/quality_assessment" },
    "judge_escalation": { "$ref": "#/$defs/judge_escalation" },
    "judge": { "$ref": "#/$defs/judge" },
    "quality_comparison": { "$ref": "#/$defs/quality_comparison" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "violations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_authority",
        "publication_allowed",
        "automatic_write_allowed",
        "llm_route_decision_allowed",
        "requires_human_approval_for_production",
        "live_effects",
        "blocked_operations"
      ],
      "properties": {
        "production_authority": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "automatic_write_allowed": { "type": "boolean", "const": false },
        "llm_route_decision_allowed": { "type": "boolean", "const": false },
        "requires_human_approval_for_production": { "type": "boolean", "const": true },
        "live_effects": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "writes_persistent_memory",
            "publishes_skill",
            "starts_timer",
            "changes_session_mechanics",
            "posts_publicly"
          ],
          "properties": {
            "writes_persistent_memory": { "type": "boolean", "const": false },
            "publishes_skill": { "type": "boolean", "const": false },
            "starts_timer": { "type": "boolean", "const": false },
            "changes_session_mechanics": { "type": "boolean", "const": false },
            "posts_publicly": { "type": "boolean", "const": false }
          }
        },
        "blocked_operations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "winner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "variant_id",
        "strategy",
        "composite_score",
        "holdout_score",
        "safety_score",
        "recommended_surface",
        "publication_allowed",
        "production_authority",
        "rationale"
      ],
      "properties": {
        "variant_id": { "type": "string", "minLength": 1 },
        "strategy": { "type": "string", "minLength": 1 },
        "composite_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "holdout_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "safety_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "recommended_surface": { "type": "string", "const": "local_draft_report_only" },
        "publication_allowed": { "type": "boolean", "const": false },
        "production_authority": { "type": "boolean", "const": false },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "experience_ledger_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ledger_id",
        "source",
        "candidate_id",
        "source_event_id",
        "route_target",
        "status",
        "retained_as",
        "lesson",
        "score",
        "evidence_count",
        "risk_level",
        "tournament_id",
        "variant_id",
        "strategy",
        "blocked_requests",
        "violations",
        "production_authority",
        "publication_allowed"
      ],
      "properties": {
        "ledger_id": { "type": "string", "minLength": 1 },
        "source": {
          "type": "string",
          "enum": ["candidate_preflight", "source_backed_preflight", "tournament_variant"]
        },
        "candidate_id": { "type": "string", "minLength": 1 },
        "source_event_id": { "type": "string", "minLength": 1 },
        "route_target": {
          "type": "string",
          "enum": ["memory", "skill", "case", "policy", "damping", "ignore"]
        },
        "status": { "type": "string", "minLength": 1 },
        "retained_as": { "type": "string", "minLength": 1 },
        "lesson": { "type": "string", "minLength": 1 },
        "score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "evidence_count": { "type": ["integer", "null"], "minimum": 0 },
        "risk_level": { "type": ["string", "null"] },
        "tournament_id": { "type": ["string", "null"] },
        "variant_id": { "type": ["string", "null"] },
        "strategy": { "type": ["string", "null"] },
        "blocked_requests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "violations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "loser_class": {
          "type": ["string", "null"],
          "enum": ["unsafe", "weak", "promising", null]
        },
        "candidate_pool_effect": {
          "type": ["string", "null"],
          "enum": [
            "strong_suppression",
            "evidence_required_before_reentry",
            "contextual_alternative",
            null
          ]
        },
        "candidate_pool_authority": {
          "type": ["string", "null"],
          "enum": ["advisory_pressure_only", null]
        },
        "candidate_pool_action": { "type": ["string", "null"] },
        "hard_filter_allowed": { "type": "boolean", "const": false },
        "agent_review_required": { "type": "boolean" },
        "l4_review_required": { "type": "boolean" },
        "review_path": { "type": ["string", "null"] },
        "review_trigger": { "type": ["string", "null"] },
        "selection_hint": { "type": ["string", "null"] },
        "reactivation_conditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "contrast": {
          "anyOf": [
            { "$ref": "#/$defs/loser_contrast" },
            { "type": "null" }
          ]
        },
        "production_authority": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false }
      }
    },
    "tournament": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tournament_id",
        "candidate_id",
        "source_event_id",
        "route_target",
        "baseline_score",
        "eval_dataset",
        "variants",
        "winner",
        "loser_ledger",
        "safety"
      ],
      "properties": {
        "tournament_id": { "type": "string", "minLength": 1 },
        "candidate_id": { "type": "string", "minLength": 1 },
        "source_event_id": { "type": "string", "minLength": 1 },
        "route_target": {
          "type": "string",
          "enum": ["memory", "skill", "case", "policy", "damping", "ignore"]
        },
        "baseline_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "eval_dataset": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total_cases", "train_count", "validation_count", "holdout_count", "cases"],
          "properties": {
            "total_cases": { "type": "integer", "minimum": 1 },
            "train_count": { "type": "integer", "minimum": 0 },
            "validation_count": { "type": "integer", "minimum": 0 },
            "holdout_count": { "type": "integer", "minimum": 0 },
            "cases": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/eval_case" }
            }
          }
        },
        "variants": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/variant" }
        },
        "winner": { "$ref": "#/$defs/winner" },
        "loser_ledger": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "variant_id",
              "status",
              "reason",
              "route_target",
              "blocked_requests",
              "becomes",
              "loser_class",
              "candidate_pool_effect",
              "candidate_pool_authority",
              "candidate_pool_action",
              "hard_filter_allowed",
              "agent_review_required",
              "l4_review_required",
              "review_path",
              "review_trigger",
              "selection_hint",
              "reactivation_conditions",
              "contrast",
              "rationale"
            ],
            "properties": {
              "variant_id": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "enum": ["winner", "loser", "rejected"] },
              "reason": { "type": "string", "minLength": 1 },
              "route_target": { "type": "string", "minLength": 1 },
              "blocked_requests": {
                "type": "array",
                "items": { "type": "string" }
              },
              "becomes": { "type": "string", "minLength": 1 },
              "loser_class": {
                "type": "string",
                "enum": ["unsafe", "weak", "promising"]
              },
              "candidate_pool_effect": {
                "type": "string",
                "enum": [
                  "strong_suppression",
                  "evidence_required_before_reentry",
                  "contextual_alternative"
                ]
              },
              "candidate_pool_authority": {
                "type": "string",
                "const": "advisory_pressure_only"
              },
              "candidate_pool_action": { "type": "string", "minLength": 1 },
              "hard_filter_allowed": { "type": "boolean", "const": false },
              "agent_review_required": { "type": "boolean", "const": true },
              "l4_review_required": { "type": "boolean" },
              "review_path": { "type": "string", "minLength": 1 },
              "review_trigger": { "type": "string", "minLength": 1 },
              "selection_hint": { "type": "string", "minLength": 1 },
              "reactivation_conditions": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "contrast": { "$ref": "#/$defs/loser_contrast" },
              "rationale": { "type": "string", "minLength": 1 }
            }
          }
        },
        "safety": { "$ref": "#/$defs/safety" }
      }
    },
    "loser_contrast": {
      "type": "object",
      "additionalProperties": false,
      "required": ["winner_variant_id", "winner_strategy", "score_margin", "key_deltas"],
      "properties": {
        "winner_variant_id": { "type": "string", "minLength": 1 },
        "winner_strategy": { "type": "string", "minLength": 1 },
        "score_margin": { "type": "number", "minimum": -1, "maximum": 1 },
        "key_deltas": {
          "type": "object",
          "additionalProperties": false,
          "required": ["safety", "holdout", "evidence_fit", "compactness", "strategy_fit"],
          "properties": {
            "safety": { "type": "number", "minimum": -1, "maximum": 1 },
            "holdout": { "type": "number", "minimum": -1, "maximum": 1 },
            "evidence_fit": { "type": "number", "minimum": -1, "maximum": 1 },
            "compactness": { "type": "number", "minimum": -1, "maximum": 1 },
            "strategy_fit": { "type": "number", "minimum": -1, "maximum": 1 }
          }
        }
      }
    },
    "quality_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "llm_api_calls", "overall_quality_score", "dimensions", "notes"],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "llm_api_calls": { "type": "integer", "minimum": 0 },
        "overall_quality_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "dimensions": { "$ref": "#/$defs/quality_dimensions" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "quality_dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_preservation",
        "safety_lock",
        "holdout_strength",
        "failure_learning",
        "compactness",
        "source_coverage"
      ],
      "properties": {
        "route_preservation": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "safety_lock": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "holdout_strength": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "failure_learning": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "compactness": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "source_coverage": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },
    "judge_escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "recommended",
        "near_threshold",
        "score",
        "threshold",
        "threshold_delta",
        "near_threshold_margin",
        "suggested_mode",
        "authority",
        "llm_api_calls",
        "dimensions",
        "llm_review_value",
        "signals",
        "reasons",
        "notes"
      ],
      "properties": {
        "mode": { "type": "string", "const": "judge_escalation_gate.v1" },
        "recommended": { "type": "boolean" },
        "near_threshold": { "type": "boolean" },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "threshold_delta": { "type": "number", "minimum": -1, "maximum": 1 },
        "near_threshold_margin": { "type": "number", "minimum": 0, "maximum": 1 },
        "suggested_mode": { "type": "string", "minLength": 1 },
        "authority": { "type": "string", "const": "llm_cannot_change_route_or_winner" },
        "llm_api_calls": { "type": "integer", "const": 0 },
        "dimensions": { "$ref": "#/$defs/judge_escalation_dimensions" },
        "llm_review_value": { "$ref": "#/$defs/llm_review_value" },
        "signals": { "$ref": "#/$defs/judge_escalation_signals" },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "llm_review_value": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "level",
        "score",
        "expected_value",
        "should_change_winner",
        "call_policy",
        "waste_risk",
        "close_winner_ratio",
        "targets",
        "notes"
      ],
      "properties": {
        "mode": { "type": "string", "const": "llm_review_value.v1" },
        "level": { "type": "string", "enum": ["none", "low", "medium", "high"] },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "expected_value": {
          "type": "string",
          "enum": ["none", "diagnostic_note_only", "critique_only"]
        },
        "should_change_winner": { "type": "boolean", "const": false },
        "call_policy": {
          "type": "string",
          "enum": ["do_not_call", "deterministic_default_review_optional", "call_when_auto_enabled"]
        },
        "waste_risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "close_winner_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "targets": {
          "type": "array",
          "items": { "$ref": "#/$defs/llm_review_target" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "llm_review_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "priority", "score", "sample_count", "evidence"],
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "sample_count": { "type": "integer", "minimum": 0 },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "judge_escalation_dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uncertainty", "value", "conflict", "novelty", "anomaly"],
      "properties": {
        "uncertainty": { "type": "number", "minimum": 0, "maximum": 1 },
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "conflict": { "type": "number", "minimum": 0, "maximum": 1 },
        "novelty": { "type": "number", "minimum": 0, "maximum": 1 },
        "anomaly": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "judge_escalation_signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "source_backed",
        "real_vps_sample",
        "route_kinds",
        "route_targets",
        "winner_strategy_diversity",
        "winner_strategy_monoculture",
        "close_winner_count",
        "rejected_reason_cluster_count",
        "repeated_rejection_pattern"
      ],
      "properties": {
        "source_kind": { "type": "string", "minLength": 1 },
        "source_backed": { "type": "boolean" },
        "real_vps_sample": { "type": "boolean" },
        "route_kinds": { "type": "integer", "minimum": 0 },
        "route_targets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "winner_strategy_diversity": { "type": "integer", "minimum": 0 },
        "winner_strategy_monoculture": { "type": "boolean" },
        "close_winner_count": { "type": "integer", "minimum": 0 },
        "rejected_reason_cluster_count": { "type": "integer", "minimum": 0 },
        "repeated_rejection_pattern": { "type": "boolean" }
      }
    },
    "judge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "status",
        "llm_api_calls",
        "model",
        "overall_quality_score",
        "dimensions",
        "notes",
        "suggested_next_experiments"
      ],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "llm_api_calls": { "type": "integer", "minimum": 0 },
        "model": { "type": ["string", "null"] },
        "overall_quality_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "dimensions": { "$ref": "#/$defs/quality_dimensions" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suggested_next_experiments": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "quality_comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "status",
        "deterministic_overall_quality_score",
        "llm_overall_quality_score",
        "delta",
        "decision_authority"
      ],
      "properties": {
        "mode": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "deterministic_overall_quality_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "llm_overall_quality_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "delta": { "type": ["number", "null"], "minimum": -1, "maximum": 1 },
        "decision_authority": { "type": "string", "const": "deterministic_qianxuesen_gate_only" }
      }
    },
    "eval_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "split", "objective", "weight", "required_checks"],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "split": { "type": "string", "enum": ["train", "validation", "holdout"] },
        "objective": { "type": "string", "minLength": 1 },
        "weight": { "type": "number", "minimum": 0 },
        "required_checks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "variant_id",
        "strategy",
        "mutation_kind",
        "route_target",
        "source_event_id",
        "proposed_change",
        "rationale",
        "procedure_outline",
        "requested_operations",
        "changed_surfaces",
        "verification_commands",
        "novelty_score",
        "safety",
        "scores",
        "constraints",
        "case_results",
        "tournament_status",
        "pareto"
      ],
      "properties": {
        "variant_id": { "type": "string", "minLength": 1 },
        "strategy": { "type": "string", "minLength": 1 },
        "mutation_kind": { "type": "string", "minLength": 1 },
        "route_target": { "type": "string", "minLength": 1 },
        "source_event_id": { "type": "string", "minLength": 1 },
        "proposed_change": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "procedure_outline": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "requested_operations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "changed_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "verification_commands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "novelty_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "safety": { "$ref": "#/$defs/safety" },
        "scores": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "route_fit",
            "evidence_fit",
            "train",
            "validation",
            "holdout",
            "safety",
            "compactness",
            "novelty",
            "strategy_fit",
            "regression",
            "composite"
          ],
          "properties": {
            "route_fit": { "type": "number", "minimum": 0, "maximum": 1 },
            "evidence_fit": { "type": "number", "minimum": 0, "maximum": 1 },
            "train": { "type": "number", "minimum": 0, "maximum": 1 },
            "validation": { "type": "number", "minimum": 0, "maximum": 1 },
            "holdout": { "type": "number", "minimum": 0, "maximum": 1 },
            "safety": { "type": "number", "minimum": 0, "maximum": 1 },
            "compactness": { "type": "number", "minimum": 0, "maximum": 1 },
            "novelty": { "type": "number", "minimum": 0, "maximum": 1 },
            "strategy_fit": { "type": "number", "minimum": 0, "maximum": 1 },
            "regression": { "type": "number", "minimum": 0, "maximum": 1 },
            "composite": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hard_gate_passed", "checks", "blocked_requests", "violations"],
          "properties": {
            "hard_gate_passed": { "type": "boolean" },
            "checks": {
              "type": "object",
              "additionalProperties": { "type": "boolean" }
            },
            "blocked_requests": {
              "type": "array",
              "items": { "type": "string" }
            },
            "violations": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "case_results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["case_id", "split", "passed", "score", "notes"],
            "properties": {
              "case_id": { "type": "string", "minLength": 1 },
              "split": { "type": "string", "enum": ["train", "validation", "holdout"] },
              "passed": { "type": "boolean" },
              "score": { "type": "number", "minimum": 0, "maximum": 1 },
              "notes": { "type": "string" }
            }
          }
        },
        "tournament_status": { "type": "string", "enum": ["winner", "loser", "rejected"] },
        "pareto": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dominated", "reason"],
          "properties": {
            "dominated": { "type": "boolean" },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
