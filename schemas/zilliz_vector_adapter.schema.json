{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/zilliz_vector_adapter.schema.json",
  "title": "ZillizVectorAdapter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "ok",
    "created_at",
    "adapter",
    "collection_plans",
    "upsert_batches",
    "metadata_checks",
    "retrieval_strategy",
    "summary",
    "safety",
    "warnings"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "misa.zilliz_vector_adapter.v1" },
    "mode": { "type": "string", "const": "zilliz-vector-adapter-dry-run" },
    "ok": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_backend",
        "execution_mode",
        "collection_strategy",
        "vector_dimension",
        "metric_type",
        "embedding_model",
        "embedding_required",
        "dynamic_metadata_allowed",
        "zilliz_written",
        "embedding_created",
        "external_api_calls"
      ],
      "properties": {
        "target_backend": { "type": "string", "const": "zilliz" },
        "execution_mode": { "type": "string", "const": "dry_run" },
        "collection_strategy": { "type": "string" },
        "vector_dimension": { "type": "integer", "minimum": 1 },
        "metric_type": { "type": "string" },
        "embedding_model": { "type": "string" },
        "embedding_required": { "type": "boolean", "const": true },
        "dynamic_metadata_allowed": { "type": "boolean" },
        "zilliz_written": { "type": "boolean", "const": false },
        "embedding_created": { "type": "boolean", "const": false },
        "external_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "collection_plans": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/collection_plan" }
    },
    "upsert_batches": {
      "type": "array",
      "items": { "$ref": "#/$defs/upsert_batch" }
    },
    "metadata_checks": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/metadata_check" }
    },
    "retrieval_strategy": { "$ref": "#/$defs/retrieval_strategy" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_count",
        "record_count",
        "batch_count",
        "by_collection",
        "records_requiring_embedding",
        "metadata_violation_count",
        "retrieval_strategy_included",
        "zilliz_write_count"
      ],
      "properties": {
        "collection_count": { "type": "integer", "minimum": 0 },
        "record_count": { "type": "integer", "minimum": 0 },
        "batch_count": { "type": "integer", "minimum": 0 },
        "by_collection": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "records_requiring_embedding": { "type": "integer", "minimum": 0 },
        "metadata_violation_count": { "type": "integer", "minimum": 0 },
        "retrieval_strategy_included": { "type": "boolean", "const": true },
        "zilliz_write_count": { "type": "integer", "const": 0 }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run",
        "zilliz_written",
        "embedding_created",
        "external_api_calls",
        "provider_credentials_read",
        "persistent_memory_written",
        "vps_or_runtime_touch_allowed",
        "live_writer_included",
        "requires_explicit_write_flag",
        "requires_reversible_probe_before_live"
      ],
      "properties": {
        "dry_run": { "type": "boolean", "const": true },
        "zilliz_written": { "type": "boolean", "const": false },
        "embedding_created": { "type": "boolean", "const": false },
        "external_api_calls": { "type": "integer", "const": 0 },
        "provider_credentials_read": { "type": "boolean", "const": false },
        "persistent_memory_written": { "type": "boolean", "const": false },
        "vps_or_runtime_touch_allowed": { "type": "boolean", "const": false },
        "live_writer_included": { "type": "boolean", "const": false },
        "requires_explicit_write_flag": { "type": "boolean", "const": true },
        "requires_reversible_probe_before_live": { "type": "boolean", "const": true }
      }
    },
    "warnings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "collection_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection",
        "description",
        "vector",
        "primary_key",
        "text_field",
        "metadata_field",
        "scalar_fields",
        "dynamic_metadata_allowed",
        "kinds",
        "local_dirs",
        "record_count"
      ],
      "properties": {
        "collection": { "type": "string" },
        "description": { "type": "string" },
        "vector": { "$ref": "#/$defs/vector_field" },
        "primary_key": { "$ref": "#/$defs/field_plan" },
        "text_field": { "$ref": "#/$defs/field_plan" },
        "metadata_field": {
          "type": "object",
          "additionalProperties": false,
          "required": ["field", "type", "required_fields"],
          "properties": {
            "field": { "type": "string" },
            "type": { "type": "string" },
            "required_fields": {
              "type": "array",
              "minItems": 10,
              "items": { "type": "string" }
            }
          }
        },
        "scalar_fields": {
          "type": "array",
          "minItems": 10,
          "items": { "$ref": "#/$defs/field_plan" }
        },
        "dynamic_metadata_allowed": { "type": "boolean" },
        "kinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "local_dirs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "record_count": { "type": "integer", "minimum": 0 }
      }
    },
    "vector_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "type",
        "dimension",
        "metric_type",
        "embedding_model",
        "embedding_required",
        "embedding_created"
      ],
      "properties": {
        "field": { "type": "string" },
        "type": { "type": "string", "const": "FloatVector" },
        "dimension": { "type": "integer", "minimum": 1 },
        "metric_type": { "type": "string" },
        "embedding_model": { "type": "string" },
        "embedding_required": { "type": "boolean", "const": true },
        "embedding_created": { "type": "boolean", "const": false }
      }
    },
    "field_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "field": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "max_length": { "type": "integer", "minimum": 1 }
      },
      "anyOf": [
        { "required": ["field"] },
        { "required": ["name"] }
      ]
    },
    "upsert_batch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection",
        "record_count",
        "zilliz_written",
        "embedding_created",
        "records"
      ],
      "properties": {
        "collection": { "type": "string" },
        "record_count": { "type": "integer", "minimum": 0 },
        "zilliz_written": { "type": "boolean", "const": false },
        "embedding_created": { "type": "boolean", "const": false },
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/upsert_record" }
        }
      }
    },
    "upsert_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "collection",
        "text",
        "embedding",
        "embedding_status",
        "embedding_required",
        "metadata"
      ],
      "properties": {
        "record_id": { "type": "string" },
        "collection": { "type": "string" },
        "text": { "type": "string", "minLength": 1 },
        "embedding": { "type": "null" },
        "embedding_status": { "type": "string", "const": "not_created" },
        "embedding_required": { "type": "boolean", "const": true },
        "metadata": { "$ref": "#/$defs/upsert_metadata" }
      }
    },
    "upsert_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "authority",
        "status",
        "risk_level",
        "source_type",
        "source_id",
        "original_source_kind",
        "original_source_id",
        "original_chunk_hash",
        "created_by",
        "promotion_state",
        "can_influence_behavior",
        "requires_owner_approval",
        "allowed_surfaces",
        "blocked_surfaces",
        "decision_trace_id",
        "original_source",
        "retrieval_trace",
        "retrieval_hints",
        "record_id",
        "title",
        "local_dir"
      ],
      "properties": {
        "kind": { "type": "string" },
        "authority": { "type": "string", "enum": ["audit_only", "candidate", "promoted", "policy"] },
        "status": { "type": "string" },
        "risk_level": { "type": "string" },
        "source_type": { "type": "string" },
        "source_id": { "type": "string" },
        "original_source_kind": { "type": "string" },
        "original_source_id": { "type": "string" },
        "original_chunk_hash": { "type": "string" },
        "created_by": { "type": "string" },
        "promotion_state": { "type": "string", "enum": ["not_promoted", "promoted"] },
        "can_influence_behavior": { "type": "boolean" },
        "requires_owner_approval": { "type": "boolean" },
        "allowed_surfaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocked_surfaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "decision_trace_id": { "type": "string" },
        "original_source": { "$ref": "#/$defs/original_source" },
        "retrieval_trace": { "$ref": "#/$defs/retrieval_trace" },
        "retrieval_hints": { "$ref": "#/$defs/retrieval_hints" },
        "record_id": { "type": "string" },
        "title": { "type": "string" },
        "local_dir": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "authority": { "enum": ["audit_only", "candidate"] } },
            "required": ["authority"]
          },
          "then": {
            "properties": { "can_influence_behavior": { "const": false } }
          }
        }
      ]
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "note"],
      "properties": {
        "kind": { "type": "string" },
        "id": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "original_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_system",
        "source_kind",
        "source_id",
        "session_id",
        "message_id",
        "artifact_path",
        "chunk_hash",
        "channel",
        "actor",
        "created_at",
        "redaction_status",
        "source_refs"
      ],
      "properties": {
        "source_system": { "type": "string" },
        "source_kind": { "type": "string" },
        "source_id": { "type": "string" },
        "session_id": { "type": "string" },
        "message_id": { "type": "string" },
        "artifact_path": { "type": "string" },
        "chunk_hash": { "type": "string" },
        "channel": { "type": "string" },
        "actor": { "type": "string" },
        "created_at": { "type": "string" },
        "redaction_status": { "type": "string" },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/source_ref" }
        }
      }
    },
    "trace_hop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "ref_type", "ref_id", "artifact_path"],
      "properties": {
        "stage": { "type": "string" },
        "ref_type": { "type": "string" },
        "ref_id": { "type": "string" },
        "artifact_path": { "type": "string" }
      }
    },
    "retrieval_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_version", "replayable", "replay_keys", "source_hops"],
      "properties": {
        "trace_version": { "type": "string", "const": "misa.retrieval_trace.v1" },
        "replayable": { "type": "boolean" },
        "replay_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source_hops": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/trace_hop" }
        }
      }
    },
    "retrieval_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filter_keys", "boost_terms", "score_inputs", "false_positive_guards"],
      "properties": {
        "filter_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "boost_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "score_inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "false_positive_guards": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "retrieval_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy_version",
        "default_top_k",
        "primary_rule",
        "same_source_rule",
        "fallback_rule",
        "kind_profiles",
        "ranking_inputs",
        "hard_rules",
        "safety"
      ],
      "properties": {
        "strategy_version": { "type": "string", "const": "misa.vector_retrieval_strategy.v1" },
        "default_top_k": { "type": "integer", "minimum": 1 },
        "primary_rule": { "type": "string" },
        "same_source_rule": { "type": "string" },
        "fallback_rule": { "type": "string" },
        "kind_profiles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/retrieval_kind_profile" }
        },
        "ranking_inputs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "hard_rules": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "safety": { "$ref": "#/$defs/retrieval_strategy_safety" }
      }
    },
    "retrieval_kind_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "collection", "authority", "support_kinds"],
      "properties": {
        "kind": { "type": "string" },
        "collection": { "type": "string" },
        "authority": { "type": "string", "enum": ["audit_only", "candidate", "promoted", "policy"] },
        "support_kinds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "retrieval_strategy_safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run",
        "zilliz_written",
        "embedding_created",
        "external_api_calls",
        "live_writer_included"
      ],
      "properties": {
        "dry_run": { "type": "boolean", "const": true },
        "zilliz_written": { "type": "boolean", "const": false },
        "embedding_created": { "type": "boolean", "const": false },
        "external_api_calls": { "type": "integer", "const": 0 },
        "live_writer_included": { "type": "boolean", "const": false }
      }
    },
    "metadata_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check", "ok", "violations"],
      "properties": {
        "check": { "type": "string" },
        "ok": { "type": "boolean" },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/metadata_violation" }
        }
      }
    },
    "metadata_violation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "check", "reason"],
      "properties": {
        "record_id": { "type": "string" },
        "check": { "type": "string" },
        "reason": { "type": "string" }
      }
    }
  }
}
