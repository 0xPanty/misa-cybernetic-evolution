{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/zilliz_vector_adapter.schema.json",
  "title": "ZillizVectorAdapter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "ok",
    "created_at",
    "adapter",
    "collection_plans",
    "upsert_batches",
    "metadata_checks",
    "summary",
    "safety",
    "warnings"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "misa.zilliz_vector_adapter.v1" },
    "mode": { "type": "string", "const": "zilliz-vector-adapter-dry-run" },
    "ok": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_backend",
        "execution_mode",
        "collection_strategy",
        "vector_dimension",
        "metric_type",
        "embedding_model",
        "embedding_required",
        "dynamic_metadata_allowed",
        "zilliz_written",
        "embedding_created",
        "external_api_calls"
      ],
      "properties": {
        "target_backend": { "type": "string", "const": "zilliz" },
        "execution_mode": { "type": "string", "const": "dry_run" },
        "collection_strategy": { "type": "string" },
        "vector_dimension": { "type": "integer", "minimum": 1 },
        "metric_type": { "type": "string" },
        "embedding_model": { "type": "string" },
        "embedding_required": { "type": "boolean", "const": true },
        "dynamic_metadata_allowed": { "type": "boolean" },
        "zilliz_written": { "type": "boolean", "const": false },
        "embedding_created": { "type": "boolean", "const": false },
        "external_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "collection_plans": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/collection_plan" }
    },
    "upsert_batches": {
      "type": "array",
      "items": { "$ref": "#/$defs/upsert_batch" }
    },
    "metadata_checks": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/metadata_check" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_count",
        "record_count",
        "batch_count",
        "by_collection",
        "records_requiring_embedding",
        "metadata_violation_count",
        "zilliz_write_count"
      ],
      "properties": {
        "collection_count": { "type": "integer", "minimum": 0 },
        "record_count": { "type": "integer", "minimum": 0 },
        "batch_count": { "type": "integer", "minimum": 0 },
        "by_collection": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "records_requiring_embedding": { "type": "integer", "minimum": 0 },
        "metadata_violation_count": { "type": "integer", "minimum": 0 },
        "zilliz_write_count": { "type": "integer", "const": 0 }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run",
        "zilliz_written",
        "embedding_created",
        "external_api_calls",
        "provider_credentials_read",
        "persistent_memory_written",
        "vps_or_runtime_touch_allowed",
        "live_writer_included",
        "requires_explicit_write_flag",
        "requires_reversible_probe_before_live"
      ],
      "properties": {
        "dry_run": { "type": "boolean", "const": true },
        "zilliz_written": { "type": "boolean", "const": false },
        "embedding_created": { "type": "boolean", "const": false },
        "external_api_calls": { "type": "integer", "const": 0 },
        "provider_credentials_read": { "type": "boolean", "const": false },
        "persistent_memory_written": { "type": "boolean", "const": false },
        "vps_or_runtime_touch_allowed": { "type": "boolean", "const": false },
        "live_writer_included": { "type": "boolean", "const": false },
        "requires_explicit_write_flag": { "type": "boolean", "const": true },
        "requires_reversible_probe_before_live": { "type": "boolean", "const": true }
      }
    },
    "warnings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "collection_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection",
        "description",
        "vector",
        "primary_key",
        "text_field",
        "metadata_field",
        "scalar_fields",
        "dynamic_metadata_allowed",
        "kinds",
        "local_dirs",
        "record_count"
      ],
      "properties": {
        "collection": { "type": "string" },
        "description": { "type": "string" },
        "vector": { "$ref": "#/$defs/vector_field" },
        "primary_key": { "$ref": "#/$defs/field_plan" },
        "text_field": { "$ref": "#/$defs/field_plan" },
        "metadata_field": {
          "type": "object",
          "additionalProperties": false,
          "required": ["field", "type", "required_fields"],
          "properties": {
            "field": { "type": "string" },
            "type": { "type": "string" },
            "required_fields": {
              "type": "array",
              "minItems": 10,
              "items": { "type": "string" }
            }
          }
        },
        "scalar_fields": {
          "type": "array",
          "minItems": 10,
          "items": { "$ref": "#/$defs/field_plan" }
        },
        "dynamic_metadata_allowed": { "type": "boolean" },
        "kinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "local_dirs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "record_count": { "type": "integer", "minimum": 0 }
      }
    },
    "vector_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "type",
        "dimension",
        "metric_type",
        "embedding_model",
        "embedding_required",
        "embedding_created"
      ],
      "properties": {
        "field": { "type": "string" },
        "type": { "type": "string", "const": "FloatVector" },
        "dimension": { "type": "integer", "minimum": 1 },
        "metric_type": { "type": "string" },
        "embedding_model": { "type": "string" },
        "embedding_required": { "type": "boolean", "const": true },
        "embedding_created": { "type": "boolean", "const": false }
      }
    },
    "field_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "field": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "max_length": { "type": "integer", "minimum": 1 }
      },
      "anyOf": [
        { "required": ["field"] },
        { "required": ["name"] }
      ]
    },
    "upsert_batch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection",
        "record_count",
        "zilliz_written",
        "embedding_created",
        "records"
      ],
      "properties": {
        "collection": { "type": "string" },
        "record_count": { "type": "integer", "minimum": 0 },
        "zilliz_written": { "type": "boolean", "const": false },
        "embedding_created": { "type": "boolean", "const": false },
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/upsert_record" }
        }
      }
    },
    "upsert_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "collection",
        "text",
        "embedding",
        "embedding_status",
        "embedding_required",
        "metadata"
      ],
      "properties": {
        "record_id": { "type": "string" },
        "collection": { "type": "string" },
        "text": { "type": "string", "minLength": 1 },
        "embedding": { "type": "null" },
        "embedding_status": { "type": "string", "const": "not_created" },
        "embedding_required": { "type": "boolean", "const": true },
        "metadata": { "$ref": "#/$defs/upsert_metadata" }
      }
    },
    "upsert_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "authority",
        "status",
        "risk_level",
        "source_type",
        "source_id",
        "created_by",
        "promotion_state",
        "can_influence_behavior",
        "requires_owner_approval",
        "allowed_surfaces",
        "blocked_surfaces",
        "decision_trace_id",
        "record_id",
        "title",
        "local_dir"
      ],
      "properties": {
        "kind": { "type": "string" },
        "authority": { "type": "string", "enum": ["audit_only", "candidate", "promoted", "policy"] },
        "status": { "type": "string" },
        "risk_level": { "type": "string" },
        "source_type": { "type": "string" },
        "source_id": { "type": "string" },
        "created_by": { "type": "string" },
        "promotion_state": { "type": "string", "enum": ["not_promoted", "promoted"] },
        "can_influence_behavior": { "type": "boolean" },
        "requires_owner_approval": { "type": "boolean" },
        "allowed_surfaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocked_surfaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "decision_trace_id": { "type": "string" },
        "record_id": { "type": "string" },
        "title": { "type": "string" },
        "local_dir": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "authority": { "enum": ["audit_only", "candidate"] } },
            "required": ["authority"]
          },
          "then": {
            "properties": { "can_influence_behavior": { "const": false } }
          }
        }
      ]
    },
    "metadata_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check", "ok", "violations"],
      "properties": {
        "check": { "type": "string" },
        "ok": { "type": "boolean" },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/metadata_violation" }
        }
      }
    },
    "metadata_violation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_id", "check", "reason"],
      "properties": {
        "record_id": { "type": "string" },
        "check": { "type": "string" },
        "reason": { "type": "string" }
      }
    }
  }
}
