{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/langgraph_qianxuesen_bridge.schema.json",
  "title": "LangGraphQianxuesenBridge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "ok",
    "created_at",
    "integration_principle",
    "langgraph_contract",
    "determinism_contract",
    "state_projection",
    "governance_hooks",
    "interrupt_queue",
    "decision_boundary",
    "safety",
    "action_policy_contract",
    "decision_bom",
    "summary",
    "warnings",
    "violations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "misa.langgraph_qianxuesen_bridge.v1"
    },
    "mode": {
      "type": "string",
      "const": "langgraph-qianxuesen-bridge"
    },
    "ok": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "integration_principle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["carrier_layer", "control_layer", "llm_agent_role", "natural_fit", "rule"],
      "properties": {
        "carrier_layer": { "type": "string", "const": "LangGraph" },
        "control_layer": { "type": "string", "const": "Qianxuesen" },
        "llm_agent_role": { "type": "string", "const": "executor_or_summarizer_only" },
        "natural_fit": { "type": "boolean", "const": true },
        "rule": { "type": "string" }
      }
    },
    "langgraph_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state_inputs", "checkpointer", "interrupt", "custom_nodes", "llm_nodes"],
      "properties": {
        "state_inputs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "checkpointer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "scope", "persist_fields", "must_not_persist_raw_private_content"],
          "properties": {
            "required": { "type": "boolean", "const": true },
            "scope": { "type": "string", "const": "learning_cycle" },
            "persist_fields": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "must_not_persist_raw_private_content": { "type": "boolean", "const": true }
          }
        },
        "interrupt": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "trigger_sources", "human_boundary", "resume_requires"],
          "properties": {
            "required": { "type": "boolean", "const": true },
            "trigger_sources": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "human_boundary": { "type": "string", "const": "human_owner" },
            "resume_requires": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        "custom_nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/custom_node" }
        },
        "llm_nodes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed_roles", "forbidden_learning_decisions"],
          "properties": {
            "allowed_roles": {
              "type": "array",
              "items": { "type": "string" }
            },
            "forbidden_learning_decisions": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "determinism_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_scope", "input_boundary", "distill", "route", "handoff"],
      "properties": {
        "claim_scope": {
          "type": "string",
          "const": "qianxuesen_sidecar_after_input_ingest"
        },
        "input_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "upstream_artifacts_may_be_llm_generated",
            "upstream_artifacts_are_evidence_not_authority",
            "raw_private_content_persisted"
          ],
          "properties": {
            "upstream_artifacts_may_be_llm_generated": { "type": "boolean", "const": true },
            "upstream_artifacts_are_evidence_not_authority": { "type": "boolean", "const": true },
            "raw_private_content_persisted": { "type": "boolean", "const": false }
          }
        },
        "distill": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "implementation",
            "deterministic_after_input",
            "uses_llm",
            "llm_api_calls",
            "external_api_calls",
            "vector_backend",
            "vector_lookup_required"
          ],
          "properties": {
            "implementation": { "type": "string", "const": "rule_symbolic_local_token_vector" },
            "deterministic_after_input": { "type": "boolean", "const": true },
            "uses_llm": { "type": "boolean", "const": false },
            "llm_api_calls": { "type": "integer", "const": 0 },
            "external_api_calls": { "type": "integer", "const": 0 },
            "vector_backend": { "type": "string", "const": "local-token-vector-v1" },
            "vector_lookup_required": { "type": "boolean", "const": false }
          }
        },
        "route": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "implementation",
            "deterministic_after_input",
            "uses_llm",
            "llm_may_override",
            "route_vocab"
          ],
          "properties": {
            "implementation": { "type": "string", "const": "signal_rules_and_route_table" },
            "deterministic_after_input": { "type": "boolean", "const": true },
            "uses_llm": { "type": "boolean", "const": false },
            "llm_may_override": { "type": "boolean", "const": false },
            "route_vocab": {
              "type": "array",
              "minItems": 6,
              "items": { "type": "string" },
              "allOf": [
                { "contains": { "const": "memory" } },
                { "contains": { "const": "skill" } },
                { "contains": { "const": "case" } },
                { "contains": { "const": "policy" } },
                { "contains": { "const": "damping" } },
                { "contains": { "const": "ignore" } }
              ]
            }
          }
        },
        "handoff": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "implementation",
            "durable_effects_require_interrupt",
            "execution_without_human"
          ],
          "properties": {
            "implementation": { "type": "string", "const": "repair_ticket_work_order_interrupt" },
            "durable_effects_require_interrupt": { "type": "boolean", "const": true },
            "execution_without_human": { "type": "boolean", "const": false }
          }
        }
      }
    },
    "state_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_source_ids",
        "repair_ticket_count",
        "work_order_count",
        "high_risk_work_order_count",
        "human_owner_work_order_count"
      ],
      "properties": {
        "evidence_source_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "repair_ticket_count": { "type": "integer", "minimum": 0 },
        "work_order_count": { "type": "integer", "minimum": 0 },
        "high_risk_work_order_count": { "type": "integer", "minimum": 0 },
        "human_owner_work_order_count": { "type": "integer", "minimum": 0 }
      }
    },
    "governance_hooks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/governance_hook" }
    },
    "interrupt_queue": {
      "type": "array",
      "items": { "$ref": "#/$defs/interrupt" }
    },
    "decision_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qianxuesen_owns", "langgraph_owns", "llm_agent_may", "llm_agent_must_not"],
      "properties": {
        "qianxuesen_owns": { "type": "array", "items": { "type": "string" } },
        "langgraph_owns": { "type": "array", "items": { "type": "string" } },
        "llm_agent_may": { "type": "array", "items": { "type": "string" } },
        "llm_agent_must_not": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_authority",
        "writes_persistent_memory",
        "publishes_skill",
        "posts_publicly",
        "touches_vps_or_services",
        "provider_route_change_allowed",
        "llm_route_decision_allowed",
        "graph_can_execute_live_effects",
        "all_durable_public_effects_require_interrupt"
      ],
      "properties": {
        "production_authority": { "type": "boolean", "const": false },
        "writes_persistent_memory": { "type": "boolean", "const": false },
        "publishes_skill": { "type": "boolean", "const": false },
        "posts_publicly": { "type": "boolean", "const": false },
        "touches_vps_or_services": { "type": "boolean", "const": false },
        "provider_route_change_allowed": { "type": "boolean", "const": false },
        "llm_route_decision_allowed": { "type": "boolean", "const": false },
        "graph_can_execute_live_effects": { "type": "boolean", "const": false },
        "all_durable_public_effects_require_interrupt": { "type": "boolean", "const": true }
      }
    },
    "action_policy_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_engine",
        "rules",
        "evaluated_action",
        "decision_trace",
        "effective_decision"
      ],
      "properties": {
        "policy_engine": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "default_action",
            "conflict_resolution",
            "evaluation_timing",
            "fail_closed",
            "llm_in_decision_loop",
            "allowed_outcomes"
          ],
          "properties": {
            "kind": { "type": "string", "const": "qianxuesen_local_rule_matrix" },
            "default_action": { "type": "string", "const": "deny" },
            "conflict_resolution": { "type": "string", "const": "deny_overrides" },
            "evaluation_timing": { "type": "string", "const": "before_control_action" },
            "fail_closed": { "type": "boolean", "const": true },
            "llm_in_decision_loop": { "type": "boolean", "const": false },
            "allowed_outcomes": {
              "type": "array",
              "minItems": 4,
              "items": { "type": "string" },
              "allOf": [
                { "contains": { "const": "allow_readonly_projection" } },
                { "contains": { "const": "allow_bounded_local_work" } },
                { "contains": { "const": "require_interrupt" } },
                { "contains": { "const": "deny" } }
              ]
            }
          }
        },
        "rules": {
          "type": "array",
          "minItems": 4,
          "items": { "$ref": "#/$defs/action_policy_rule" },
          "allOf": [
            { "contains": { "properties": { "rule_id": { "const": "deny_llm_learning_authority" } }, "required": ["rule_id"] } },
            { "contains": { "properties": { "rule_id": { "const": "require_interrupt_for_durable_or_public_effect" } }, "required": ["rule_id"] } },
            { "contains": { "properties": { "rule_id": { "const": "allow_qianxuesen_readonly_projection" } }, "required": ["rule_id"] } },
            { "contains": { "properties": { "rule_id": { "const": "allow_bounded_local_work_after_policy" } }, "required": ["rule_id"] } }
          ]
        },
        "evaluated_action": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "action_type",
            "work_order_count",
            "interrupt_count",
            "durable_or_public_effect_count",
            "blocked_surfaces"
          ],
          "properties": {
            "action_type": { "type": "string", "const": "learning_route_and_work_order_handoff" },
            "work_order_count": { "type": "integer", "minimum": 0 },
            "interrupt_count": { "type": "integer", "minimum": 0 },
            "durable_or_public_effect_count": { "type": "integer", "minimum": 0 },
            "blocked_surfaces": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "decision_trace": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/action_policy_decision_trace" }
        },
        "effective_decision": {
          "type": "string",
          "enum": [
            "allow_readonly_projection",
            "allow_bounded_local_work",
            "require_interrupt",
            "deny"
          ]
        }
      }
    },
    "decision_bom": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "reconstruction_mode",
        "decision_id",
        "reconstructed_at",
        "sources_queried",
        "required_fields",
        "missing_required_fields",
        "completeness_score",
        "integrity_hash"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "misa.qianxuesen_decision_bom.v1"
        },
        "reconstruction_mode": {
          "type": "string",
          "const": "from_existing_bridge_signals"
        },
        "decision_id": {
          "type": "string",
          "pattern": "^bridge-[a-f0-9]{16}$"
        },
        "reconstructed_at": { "type": "string", "format": "date-time" },
        "sources_queried": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string" },
          "allOf": [
            { "contains": { "const": "state_projection" } },
            { "contains": { "const": "governance_hooks" } },
            { "contains": { "const": "action_policy_contract" } },
            { "contains": { "const": "interrupt_queue" } },
            { "contains": { "const": "decision_boundary" } }
          ]
        },
        "required_fields": {
          "type": "array",
          "minItems": 6,
          "items": { "$ref": "#/$defs/decision_bom_field" },
          "allOf": [
            { "contains": { "properties": { "name": { "const": "control_owner" } }, "required": ["name"] } },
            { "contains": { "properties": { "name": { "const": "policy_rules_evaluated" } }, "required": ["name"] } },
            { "contains": { "properties": { "name": { "const": "action_type" } }, "required": ["name"] } },
            { "contains": { "properties": { "name": { "const": "decision_outcome" } }, "required": ["name"] } },
            { "contains": { "properties": { "name": { "const": "evidence_source_refs" } }, "required": ["name"] } },
            { "contains": { "properties": { "name": { "const": "human_boundary_status" } }, "required": ["name"] } }
          ]
        },
        "missing_required_fields": {
          "type": "array",
          "maxItems": 0,
          "items": { "type": "string" }
        },
        "completeness_score": { "type": "number", "const": 1 },
        "integrity_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_order_count",
        "interrupt_count",
        "deterministic_governance_node_count",
        "governance_hook_count",
        "llm_owned_learning_decision_count",
        "live_effect_allowed",
        "action_policy_effective_decision",
        "decision_bom_completeness_score",
        "verifier"
      ],
      "properties": {
        "work_order_count": { "type": "integer", "minimum": 0 },
        "interrupt_count": { "type": "integer", "minimum": 0 },
        "deterministic_governance_node_count": { "type": "integer", "minimum": 1 },
        "governance_hook_count": { "type": "integer", "minimum": 1 },
        "llm_owned_learning_decision_count": { "type": "integer", "const": 0 },
        "live_effect_allowed": { "type": "boolean", "const": false },
        "action_policy_effective_decision": {
          "type": "string",
          "enum": [
            "allow_readonly_projection",
            "allow_bounded_local_work",
            "require_interrupt",
            "deny"
          ]
        },
        "decision_bom_completeness_score": { "type": "number", "const": 1 },
        "verifier": { "type": "string", "enum": ["passed", "failed"] }
      }
    },
    "warnings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "violations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "custom_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "node_id", "owner", "calls", "llm_decision_allowed", "description"],
      "properties": {
        "stage_id": { "type": "string" },
        "node_id": { "type": "string" },
        "owner": { "type": "string", "const": "qianxuesen_deterministic" },
        "calls": { "type": "string" },
        "llm_decision_allowed": { "type": "boolean", "const": false },
        "description": { "type": "string" }
      }
    },
    "governance_hook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "after_node",
        "from_node",
        "to_node",
        "hook",
        "owner",
        "input_from_state",
        "output_to_state",
        "must_be_deterministic",
        "llm_may_override"
      ],
      "properties": {
        "stage_id": { "type": "string" },
        "after_node": { "type": "string" },
        "from_node": { "type": "string" },
        "to_node": { "type": "string" },
        "hook": { "type": "string" },
        "owner": { "type": "string", "const": "qianxuesen_deterministic" },
        "input_from_state": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "output_to_state": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "must_be_deterministic": { "type": "boolean", "const": true },
        "llm_may_override": { "type": "boolean", "const": false }
      }
    },
    "action_policy_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "stage_id", "priority", "match", "decision"],
      "properties": {
        "rule_id": { "type": "string" },
        "stage_id": { "type": "string" },
        "priority": { "type": "integer" },
        "match": { "type": "string" },
        "decision": {
          "type": "string",
          "enum": [
            "allow_readonly_projection",
            "allow_bounded_local_work",
            "require_interrupt",
            "deny"
          ]
        }
      }
    },
    "action_policy_decision_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "matched_rule", "decision"],
      "properties": {
        "stage_id": { "type": "string" },
        "matched_rule": { "type": "string" },
        "decision": {
          "type": "string",
          "enum": [
            "allow_readonly_projection",
            "allow_bounded_local_work",
            "require_interrupt",
            "deny"
          ]
        },
        "applied_to_llm_attempts_only": { "type": "boolean" },
        "observed_llm_attempt_count": { "type": "integer", "minimum": 0 }
      }
    },
    "decision_bom_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "category", "value", "source", "present", "inferred"],
      "properties": {
        "name": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["identity", "policy", "action", "outcome", "lineage", "boundary"]
        },
        "value": {},
        "source": { "type": "string" },
        "present": { "type": "boolean", "const": true },
        "inferred": { "type": "boolean" }
      }
    },
    "interrupt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interrupt_id",
        "source_type",
        "source_id",
        "title",
        "reason",
        "suggested_executor",
        "requires_user_confirmation",
        "owner_report_required",
        "durable_or_public_effect",
        "effect_boundary",
        "resume_policy"
      ],
      "properties": {
        "interrupt_id": { "type": "string" },
        "source_type": { "type": "string" },
        "source_id": { "type": "string" },
        "title": { "type": "string" },
        "reason": { "type": "string" },
        "suggested_executor": { "type": "string" },
        "requires_user_confirmation": { "type": "boolean" },
        "owner_report_required": { "type": "boolean" },
        "durable_or_public_effect": { "type": "boolean" },
        "effect_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "durable_or_public_effect",
            "execution_allowed_without_human",
            "requires_interrupt",
            "blocked_surfaces",
            "source_policy"
          ],
          "properties": {
            "durable_or_public_effect": { "type": "boolean" },
            "execution_allowed_without_human": { "type": "boolean", "const": false },
            "requires_interrupt": { "type": "boolean", "const": true },
            "blocked_surfaces": {
              "type": "array",
              "items": { "type": "string" }
            },
            "source_policy": { "type": "string" }
          }
        },
        "resume_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "human_owner_required",
            "accepted_decisions",
            "require_source_refs",
            "require_approval_record"
          ],
          "properties": {
            "human_owner_required": { "type": "boolean" },
            "accepted_decisions": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "require_source_refs": { "type": "boolean", "const": true },
            "require_approval_record": { "type": "boolean", "const": true }
          }
        }
      }
    }
  }
}
