{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/self_repair_run.schema.json",
  "title": "SelfRepairRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "candidate_id",
    "mode",
    "status",
    "attempts",
    "write_scope",
    "generated_files",
    "commands",
    "safety",
    "needs_human_review",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "misa.self_repair_run.v1"
    },
    "run_id": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "const": "self-repair-draft"
    },
    "status": {
      "type": "string",
      "enum": ["draft_generated", "validated_draft", "failed_repair", "needs_human_review"]
    },
    "attempts": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2
    },
    "write_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "generated/skill-drafts",
          "generated/repair-plans",
          "runs/self-repair"
        ]
      }
    },
    "generated_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "command", "exit_code", "timed_out", "duration_ms"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "timed_out": { "type": "boolean" },
          "duration_ms": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_allowed",
        "writes_persistent_memory",
        "touches_runtime",
        "starts_timer_or_service",
        "requires_human_publish_approval"
      ],
      "properties": {
        "publication_allowed": { "type": "boolean", "const": false },
        "writes_persistent_memory": { "type": "boolean", "const": false },
        "touches_runtime": { "type": "boolean", "const": false },
        "starts_timer_or_service": { "type": "boolean", "const": false },
        "requires_human_publish_approval": { "type": "boolean", "const": true }
      }
    },
    "needs_human_review": { "type": "boolean" },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
