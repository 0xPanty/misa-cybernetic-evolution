{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/deployment-ticket.schema.json",
  "title": "DeploymentTicket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "deployment_id",
    "candidate_id",
    "candidate_kind",
    "route_target",
    "review_route",
    "setpoint_metric_id",
    "target_value",
    "tolerance",
    "direction",
    "pre_deploy_value",
    "post_deploy_value",
    "measurement_window",
    "decision_at_window_end",
    "measurement",
    "rollback",
    "damping",
    "safety",
    "evidence"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "misa.deployment_ticket.v1" },
    "deployment_id": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "candidate_kind": {
      "type": "string",
      "enum": ["skill", "memory", "case", "policy"]
    },
    "route_target": {
      "type": "string",
      "enum": ["skill", "memory", "case", "policy"]
    },
    "review_route": { "type": "string", "const": "post_deploy_review" },
    "setpoint_metric_id": { "type": "string", "minLength": 1 },
    "target_value": { "type": "number" },
    "tolerance": { "type": "number", "minimum": 0 },
    "direction": {
      "type": "string",
      "enum": ["minimize", "maximize", "hold_within"]
    },
    "pre_deploy_value": { "type": "number" },
    "post_deploy_value": { "type": ["number", "null"] },
    "measurement_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "enum": ["days", "sessions", "samples"] },
        "value": { "type": "integer", "minimum": 1 }
      }
    },
    "decision_at_window_end": {
      "type": "string",
      "enum": ["pending", "confirmed_positive", "confirmed_negative", "null_effect"]
    },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classifier",
        "pre_distance_to_target",
        "post_distance_to_target",
        "delta_toward_target",
        "within_tolerance",
        "llm_api_calls"
      ],
      "properties": {
        "classifier": {
          "type": "string",
          "const": "deterministic_distance_to_setpoint_v1"
        },
        "pre_distance_to_target": { "type": "number", "minimum": 0 },
        "post_distance_to_target": { "type": ["number", "null"], "minimum": 0 },
        "delta_toward_target": { "type": ["number", "null"] },
        "within_tolerance": { "type": ["boolean", "null"] },
        "llm_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recommended", "executed", "authority", "reason"],
      "properties": {
        "recommended": { "type": "boolean" },
        "executed": { "type": "boolean", "const": false },
        "authority": {
          "type": "string",
          "const": "human_or_production_plane_only"
        },
        "reason": { "type": ["string", "null"] }
      }
    },
    "damping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recommended", "case_candidate", "reason"],
      "properties": {
        "recommended": { "type": "boolean" },
        "case_candidate": { "type": "boolean" },
        "reason": { "type": ["string", "null"] }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_authority",
        "publication_allowed",
        "persistent_write_allowed",
        "rollback_executed",
        "llm_api_calls",
        "external_api_calls"
      ],
      "properties": {
        "production_authority": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "persistent_write_allowed": { "type": "boolean", "const": false },
        "rollback_executed": { "type": "boolean", "const": false },
        "llm_api_calls": { "type": "integer", "const": 0 },
        "external_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "note"],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "note": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
