{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/prompt_template_manifest.schema.json",
  "title": "PromptTemplateManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "templates", "policy"],
  "properties": {
    "schema_version": { "type": "string", "const": "misa.prompt_template_manifest.v1" },
    "mode": { "type": "string", "const": "versioned-prompt-templates" },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["template_id", "version", "path", "variables", "purpose", "allowed_outputs", "forbidden_outputs"],
        "properties": {
          "template_id": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "variables": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "purpose": { "type": "string", "minLength": 1 },
          "allowed_outputs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "forbidden_outputs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_string_concatenation_allowed",
        "unversioned_prompt_allowed",
        "llm_may_choose_template",
        "template_changes_require_review"
      ],
      "properties": {
        "runtime_string_concatenation_allowed": { "type": "boolean", "const": false },
        "unversioned_prompt_allowed": { "type": "boolean", "const": false },
        "llm_may_choose_template": { "type": "boolean", "const": false },
        "template_changes_require_review": { "type": "boolean", "const": true }
      }
    }
  }
}
