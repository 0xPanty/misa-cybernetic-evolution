{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/skill_crystallization_candidate.schema.json",
  "title": "SkillCrystallizationCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "source_event_id",
    "source_cycle_id",
    "one_line_summary",
    "trigger_conditions",
    "route",
    "evidence",
    "proposed_skill",
    "procedure_outline",
    "quality",
    "verification_commands",
    "self_repair",
    "safety",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "misa.skill_crystallization_candidate.v2"
    },
    "candidate_id": { "type": "string", "minLength": 1 },
    "source_event_id": { "type": "string", "minLength": 1 },
    "source_cycle_id": { "type": "string", "minLength": 1 },
    "one_line_summary": { "type": "string", "minLength": 1 },
    "trigger_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "candidate_action", "affected_artifacts"],
      "properties": {
        "target": {
          "type": "string",
          "const": "skill"
        },
        "candidate_action": {
          "type": "string",
          "enum": ["create", "improve"]
        },
        "affected_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_basis", "artifact_evidence"],
      "properties": {
        "evidence_basis": { "type": "string", "minLength": 1 },
        "artifact_evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["injected", "read", "modified", "referenced", "tool_errors"],
          "properties": {
            "injected": {
              "type": "array",
              "items": { "type": "string" }
            },
            "read": {
              "type": "array",
              "items": { "type": "string" }
            },
            "modified": {
              "type": "array",
              "items": { "type": "string" }
            },
            "referenced": {
              "type": "array",
              "items": { "type": "string" }
            },
            "tool_errors": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "proposed_skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "title", "action", "proposed_path", "target_surface"],
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "title": { "type": "string", "minLength": 1 },
        "action": {
          "type": "string",
          "enum": ["create", "improve"]
        },
        "proposed_path": {
          "type": "string",
          "pattern": "^generated/skill-drafts/[a-z0-9][a-z0-9-]*\\.md$"
        },
        "target_surface": {
          "type": "string",
          "const": "draft_skill"
        }
      }
    },
    "procedure_outline": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "ready_for_draft", "ready_for_publish", "missing_fields", "rationale"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ready_for_draft": { "type": "boolean" },
        "ready_for_publish": {
          "type": "boolean",
          "const": false
        },
        "missing_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rationale": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "verification_commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "self_repair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "mode",
        "write_scope",
        "max_auto_fix_attempts",
        "requires_human_publish_approval"
      ],
      "properties": {
        "allowed": {
          "type": "boolean",
          "const": true
        },
        "mode": {
          "type": "string",
          "const": "draft_only"
        },
        "write_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "generated/skill-drafts",
              "generated/repair-plans",
              "runs/self-repair"
            ]
          }
        },
        "max_auto_fix_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "requires_human_publish_approval": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publication_allowed", "live_effects", "blocked_operations"],
      "properties": {
        "publication_allowed": {
          "type": "boolean",
          "const": false
        },
        "live_effects": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "writes_persistent_memory",
            "publishes_skill",
            "starts_timer",
            "changes_session_mechanics",
            "posts_publicly"
          ],
          "properties": {
            "writes_persistent_memory": { "type": "boolean", "const": false },
            "publishes_skill": { "type": "boolean", "const": false },
            "starts_timer": { "type": "boolean", "const": false },
            "changes_session_mechanics": { "type": "boolean", "const": false },
            "posts_publicly": { "type": "boolean", "const": false }
          }
        },
        "blocked_operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "persistent_memory_write",
              "zilliz_replacement",
              "farcaster_publish",
              "skill_publication",
              "session_mechanic_replacement",
              "timer_or_service_start"
            ]
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
