{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/session_distillation_review.schema.json",
  "title": "SessionDistillationReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "ok",
    "summary",
    "distillates",
    "learning_events",
    "lesson_splitter",
    "safety",
    "checks",
    "warnings",
    "violations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "misa.local_session_distillation.v1"
    },
    "mode": {
      "type": "string",
      "const": "local-session-distillation"
    },
    "ok": { "type": "boolean" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_count",
        "distillate_count",
        "learning_event_count",
        "llm_api_calls",
        "external_api_calls",
        "zilliz_proxy_used",
        "local_vector_index_used",
        "vector_store_backend",
        "vector_lookup_required",
        "raw_window_default",
        "segment_count",
        "atomic_lesson_count",
        "compound_source_count",
        "production_authority"
      ],
      "properties": {
        "source_count": { "type": "integer", "minimum": 1 },
        "distillate_count": { "type": "integer", "minimum": 1 },
        "learning_event_count": { "type": "integer", "minimum": 1 },
        "llm_api_calls": { "type": "integer", "const": 0 },
        "external_api_calls": { "type": "integer", "const": 0 },
        "zilliz_proxy_used": { "type": "boolean", "const": false },
        "local_vector_index_used": { "type": "boolean", "const": true },
        "vector_store_backend": { "type": "string", "const": "local-token-vector-v1" },
        "vector_lookup_required": { "type": "boolean", "const": false },
        "raw_window_default": { "type": "boolean", "const": false },
        "segment_count": { "type": "integer", "minimum": 1 },
        "atomic_lesson_count": { "type": "integer", "minimum": 1 },
        "compound_source_count": { "type": "integer", "minimum": 0 },
        "production_authority": { "type": "boolean", "const": false }
      }
    },
    "distillates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "distillate_id",
          "source_id",
          "source_kind",
          "channel",
          "summary",
          "source_refs",
          "segments",
          "extracted_signals",
          "extraction",
          "local_vector_index",
          "input_policy",
          "learning_event_id",
          "learning_event_ids",
          "atomic_lesson_count"
        ],
        "properties": {
          "distillate_id": { "type": "string", "minLength": 1 },
          "source_id": { "type": "string", "minLength": 1 },
          "source_kind": { "type": "string", "minLength": 1 },
          "channel": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "segments": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["segment_id", "source_ref", "speaker", "redacted_text", "token_count", "signals"],
              "properties": {
                "segment_id": { "type": "string", "minLength": 1 },
                "source_ref": { "type": "string", "minLength": 1 },
                "speaker": { "type": "string", "minLength": 1 },
                "redacted_text": { "type": "string", "minLength": 1 },
                "token_count": { "type": "integer", "minimum": 1 },
                "signals": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "uniqueItems": true
                }
              }
            }
          },
          "extracted_signals": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "extraction": {
            "type": "object",
            "additionalProperties": false,
            "required": ["summary", "setpoint", "evidence_count", "outcome", "risk_level", "artifact_evidence"],
            "properties": {
              "summary": { "type": "string", "minLength": 1 },
              "setpoint": { "type": "string", "minLength": 1 },
              "evidence_count": { "type": "integer", "minimum": 1 },
              "outcome": {
                "type": "string",
                "enum": ["success", "partial", "failure", "unknown"]
              },
              "risk_level": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "artifact_evidence": { "type": "object" }
            }
          },
          "local_vector_index": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "backend",
              "persistence",
              "dimensions",
              "item_count",
              "uses_zilliz_proxy",
              "external_api_calls",
              "vectors"
            ],
            "properties": {
              "backend": { "type": "string", "const": "local-token-vector-v1" },
              "persistence": { "type": "string", "const": "in_memory_report" },
              "dimensions": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              },
              "item_count": { "type": "integer", "minimum": 1 },
              "uses_zilliz_proxy": { "type": "boolean", "const": false },
              "external_api_calls": { "type": "integer", "const": 0 },
              "vectors": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "object" }
              }
            }
          },
          "input_policy": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "local_only",
              "summary_first",
              "raw_window_default",
              "uses_zilliz_proxy",
              "local_vector_index",
              "vector_lookup_required",
              "llm_api_calls",
              "external_api_calls"
            ],
            "properties": {
              "local_only": { "type": "boolean", "const": true },
              "summary_first": { "type": "boolean", "const": true },
              "raw_window_default": { "type": "boolean", "const": false },
              "uses_zilliz_proxy": { "type": "boolean", "const": false },
              "local_vector_index": { "type": "boolean", "const": true },
              "vector_lookup_required": { "type": "boolean", "const": false },
              "llm_api_calls": { "type": "integer", "const": 0 },
              "external_api_calls": { "type": "integer", "const": 0 }
            }
          },
          "learning_event_id": { "type": "string", "minLength": 1 },
          "learning_event_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "atomic_lesson_count": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "learning_events": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    },
    "lesson_splitter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "mode",
        "source_count",
        "atomic_lesson_count",
        "compound_source_count",
        "route_counts",
        "local_only",
        "writes_persistent_memory",
        "installs_skills",
        "updates_vps",
        "llm_api_calls",
        "external_api_calls"
      ],
      "properties": {
        "enabled": { "type": "boolean", "const": true },
        "mode": { "type": "string", "const": "deterministic-atomic-lessons-v1" },
        "source_count": { "type": "integer", "minimum": 1 },
        "atomic_lesson_count": { "type": "integer", "minimum": 1 },
        "compound_source_count": { "type": "integer", "minimum": 0 },
        "route_counts": { "type": "object" },
        "local_only": { "type": "boolean", "const": true },
        "writes_persistent_memory": { "type": "boolean", "const": false },
        "installs_skills": { "type": "boolean", "const": false },
        "updates_vps": { "type": "boolean", "const": false },
        "llm_api_calls": { "type": "integer", "const": 0 },
        "external_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_authority",
        "publication_allowed",
        "writes_persistent_memory",
        "uses_zilliz_proxy",
        "llm_api_calls",
        "external_api_calls"
      ],
      "properties": {
        "production_authority": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "writes_persistent_memory": { "type": "boolean", "const": false },
        "uses_zilliz_proxy": { "type": "boolean", "const": false },
        "llm_api_calls": { "type": "integer", "const": 0 },
        "external_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "ok", "reason"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "ok": { "type": "boolean" },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "violations": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
