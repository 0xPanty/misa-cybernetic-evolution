{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/misa-cybernetic-evolution/agent_runtime_adapter.schema.json",
  "title": "AgentRuntimeAdapter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "ok",
    "created_at",
    "adapter",
    "universal_contract",
    "hook_mapping",
    "normalized_events",
    "research_digests",
    "evolution_candidates",
    "boundary_observations",
    "observability_stream",
    "work_order_stream",
    "anomaly_rules",
    "observability_retention",
    "migration_dry_run",
    "control_plane_write_deny",
    "plugin_contract",
    "summary",
    "safety",
    "checks",
    "warnings",
    "violations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "misa.agent_runtime_adapter.v1"
    },
    "mode": {
      "type": "string",
      "const": "hermes-runtime-adapter"
    },
    "ok": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter_id", "runtime", "runtime_commit", "source_url", "entry_strategy", "default_mode"],
      "properties": {
        "adapter_id": { "type": "string" },
        "runtime": { "type": "string" },
        "runtime_commit": { "type": "string" },
        "source_url": { "type": "string" },
        "entry_strategy": { "type": "string" },
        "default_mode": { "type": "string", "const": "observe_only" }
      }
    },
    "universal_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_role",
        "control_owner",
        "framework_role",
        "route_vocab",
        "accepts_external_information",
        "candidate_pool_policy",
        "direct_write_policy",
        "runtime_specific_code_required"
      ],
      "properties": {
        "adapter_role": { "type": "string", "const": "runtime_event_normalizer" },
        "control_owner": { "type": "string", "const": "qianxuesen" },
        "framework_role": { "type": "string", "const": "carrier_runtime" },
        "route_vocab": {
          "type": "array",
          "minItems": 6,
          "items": { "type": "string" },
          "allOf": [
            { "contains": { "const": "memory" } },
            { "contains": { "const": "skill" } },
            { "contains": { "const": "case" } },
            { "contains": { "const": "policy" } },
            { "contains": { "const": "damping" } },
            { "contains": { "const": "ignore" } }
          ]
        },
        "accepts_external_information": { "type": "boolean", "const": true },
        "candidate_pool_policy": { "type": "string", "const": "boundary_observation_or_explicit_evolution_evidence_only" },
        "direct_write_policy": { "type": "string", "const": "forbidden_by_default" },
        "runtime_specific_code_required": { "type": "boolean", "const": true }
      }
    },
    "hook_mapping": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/hook_mapping" }
    },
    "normalized_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/normalized_event" }
    },
    "research_digests": {
      "type": "array",
      "items": { "$ref": "#/$defs/research_digest" }
    },
    "evolution_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/evolution_candidate" }
    },
    "boundary_observations": {
      "type": "array",
      "items": { "$ref": "#/$defs/evolution_candidate" }
    },
    "observability_stream": {
      "type": "array",
      "items": { "$ref": "#/$defs/observability_record" }
    },
    "work_order_stream": {
      "type": "array",
      "items": { "$ref": "#/$defs/evolution_candidate" }
    },
    "anomaly_rules": { "$ref": "#/$defs/anomaly_rule_registry" },
    "observability_retention": { "$ref": "#/$defs/observability_retention" },
    "migration_dry_run": { "$ref": "#/$defs/migration_dry_run" },
    "control_plane_write_deny": { "$ref": "#/$defs/control_plane_write_deny" },
    "plugin_contract": { "$ref": "#/$defs/plugin_contract" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_count",
        "normalized_event_count",
        "research_digest_count",
        "evolution_candidate_count",
        "official_evolution_candidate_count",
        "qianxuesen_replay_synthesis_count",
        "inferred_evolution_pressure_count",
        "boundary_observation_count",
        "observability_stream_count",
        "work_order_stream_count",
        "sidecar_signal_to_noise_ratio",
        "replay_required_count",
        "tournament_required_count",
        "skill_manage_event_count",
        "memory_write_event_count",
        "external_information_event_count",
        "evolution_evidence_count",
        "holdout_evidence_count",
        "positive_optimization_evidence_count",
        "insufficient_evidence_summary",
        "default_mode",
        "verifier"
      ],
      "properties": {
        "event_count": { "type": "integer", "minimum": 0 },
        "normalized_event_count": { "type": "integer", "minimum": 0 },
        "research_digest_count": { "type": "integer", "minimum": 0 },
        "evolution_candidate_count": { "type": "integer", "minimum": 0 },
        "official_evolution_candidate_count": { "type": "integer", "minimum": 0 },
        "qianxuesen_replay_synthesis_count": { "type": "integer", "minimum": 0 },
        "inferred_evolution_pressure_count": { "type": "integer", "minimum": 0 },
        "boundary_observation_count": { "type": "integer", "minimum": 0 },
        "observability_stream_count": { "type": "integer", "minimum": 0 },
        "work_order_stream_count": { "type": "integer", "minimum": 0 },
        "sidecar_signal_to_noise_ratio": { "$ref": "#/$defs/sidecar_signal_to_noise_ratio" },
        "replay_required_count": { "type": "integer", "minimum": 0 },
        "tournament_required_count": { "type": "integer", "minimum": 0 },
        "skill_manage_event_count": { "type": "integer", "minimum": 0 },
        "memory_write_event_count": { "type": "integer", "minimum": 0 },
        "external_information_event_count": { "type": "integer", "minimum": 0 },
        "evolution_evidence_count": { "type": "integer", "minimum": 0 },
        "holdout_evidence_count": { "type": "integer", "minimum": 0 },
        "positive_optimization_evidence_count": { "type": "integer", "minimum": 0 },
        "insufficient_evidence_summary": { "$ref": "#/$defs/insufficient_evidence_summary" },
        "default_mode": { "type": "string", "const": "observe_only" },
        "verifier": { "type": "string", "enum": ["passed", "failed"] }
      }
    },
    "safety": { "$ref": "#/$defs/safety" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "violations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_quality": {
      "type": "string",
      "enum": ["sufficient", "insufficient_evidence", "gaming_suspected"]
    },
    "signal_origin": {
      "type": "string",
      "enum": [
        "runtime_operation_log",
        "hermes_official_self_evolution",
        "qianxuesen_replay_synthesis"
      ]
    },
    "interpretation": {
      "type": "string",
      "enum": [
        "adapter_inferred_evolution_pressure",
        "official_evolution_candidate",
        "replay_synthesized_evidence"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "routing_stream": {
      "type": "string",
      "enum": ["observability_stream", "work_order_stream"]
    },
    "source_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": { "type": "string", "enum": ["time", "count"] },
        "value": { "type": "string" }
      }
    },
    "insufficient_evidence_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_count",
        "event_type",
        "source_window",
        "insufficient_count",
        "insufficient_ratio"
      ],
      "properties": {
        "sample_count": { "type": "integer", "minimum": 0 },
        "event_type": { "type": "string", "const": "evolution_candidate" },
        "source_window": { "$ref": "#/$defs/source_window" },
        "insufficient_count": { "type": "integer", "minimum": 0 },
        "insufficient_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "sidecar_signal_to_noise_ratio": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "formula",
        "source_contract",
        "numerator",
        "denominator",
        "value",
        "target_band",
        "status"
      ],
      "properties": {
        "metric_id": { "type": "string", "const": "sidecar_signal_to_noise_ratio" },
        "formula": { "type": "string" },
        "source_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "llm_api_calls"],
          "properties": {
            "kind": { "type": "string", "const": "deterministic_reducer" },
            "llm_api_calls": { "type": "integer", "const": 0 }
          }
        },
        "numerator": { "type": "integer", "minimum": 0 },
        "denominator": { "type": "integer", "minimum": 0 },
        "value": { "type": "number", "minimum": 0 },
        "target_band": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "number", "minimum": 0 },
            "max": { "type": "number", "minimum": 0 }
          }
        },
        "status": {
          "type": "string",
          "enum": ["inside_target_band", "too_noisy", "possibly_too_quiet", "not_applicable"]
        }
      }
    },
    "anomaly_rule_registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry_id", "version", "rules"],
      "properties": {
        "registry_id": { "type": "string" },
        "version": { "type": "string" },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rule_id", "version", "registered_at", "rule_definition", "deterministic_reducer"],
            "properties": {
              "rule_id": { "type": "string" },
              "version": { "type": "string" },
              "registered_at": { "type": "string", "format": "date-time" },
              "rule_definition": { "type": "string" },
              "deterministic_reducer": { "type": "boolean", "const": true }
            }
          }
        }
      }
    },
    "observability_retention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_events_window",
        "aggregated_stats_window",
        "compaction_on_overflow",
        "enforcement_mode"
      ],
      "properties": {
        "raw_events_window": { "type": "string" },
        "aggregated_stats_window": { "type": "string" },
        "compaction_on_overflow": { "type": "boolean" },
        "enforcement_mode": { "type": "string", "const": "declared_only_no_deletion" }
      }
    },
    "migration_dry_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "source",
        "original_count",
        "work_order_stream_count",
        "observability_stream_count",
        "history_write_performed",
        "action",
        "reclassified_marker"
      ],
      "properties": {
        "mode": { "type": "string", "const": "dry_run_only" },
        "source": { "type": "string", "const": "legacy_evolution_candidates" },
        "original_count": { "type": "integer", "minimum": 0 },
        "work_order_stream_count": { "type": "integer", "minimum": 0 },
        "observability_stream_count": { "type": "integer", "minimum": 0 },
        "history_write_performed": { "type": "boolean", "const": false },
        "action": { "type": "string", "const": "report_only_no_ledger_mutation" },
        "reclassified_marker": { "type": "string", "const": "retroactively_reclassified_on_report_only" }
      }
    },
    "hook_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hook",
        "hermes_surface",
        "qianxuesen_stage",
        "qianxuesen_event_type",
        "can_block_runtime",
        "default_blocks_runtime"
      ],
      "properties": {
        "hook": { "type": "string" },
        "hermes_surface": { "type": "string" },
        "qianxuesen_stage": { "type": "string" },
        "qianxuesen_event_type": { "type": "string" },
        "can_block_runtime": { "type": "boolean" },
        "default_blocks_runtime": { "type": "boolean", "const": false }
      }
    },
    "normalized_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "normalized_event_id",
        "source_event_id",
        "runtime_hook",
        "hook_family",
        "runtime_surface",
        "tool_name",
        "runtime_action",
        "qianxuesen_event_type",
        "route_target",
        "observed_signals",
        "observed_terms",
        "signal_origin",
        "interpretation",
        "confidence",
        "confidence_rule_id",
        "evidence_refs",
        "action_identity_fingerprint",
        "source_payload_fingerprint",
        "effect_boundary",
        "control_decision"
      ],
      "properties": {
        "normalized_event_id": { "type": "string" },
        "source_event_id": { "type": "string" },
        "runtime_hook": { "type": "string" },
        "hook_family": { "type": "string" },
        "runtime_surface": { "type": "string" },
        "tool_name": { "type": ["string", "null"] },
        "runtime_action": { "type": ["string", "null"] },
        "qianxuesen_event_type": { "type": "string" },
        "route_target": {
          "type": "string",
          "enum": ["memory", "skill", "case", "policy", "damping", "ignore"]
        },
        "observed_signals": { "$ref": "#/$defs/string_array" },
        "observed_terms": { "$ref": "#/$defs/string_array" },
        "signal_origin": { "$ref": "#/$defs/signal_origin" },
        "interpretation": { "$ref": "#/$defs/interpretation" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "confidence_rule_id": { "type": "string" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "action_identity_fingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source_payload_fingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "evolution_evidence": { "$ref": "#/$defs/evolution_evidence" },
        "effect_boundary": { "$ref": "#/$defs/effect_boundary" },
        "control_decision": { "$ref": "#/$defs/control_decision" }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "persistent_memory_write_requested",
        "skill_write_requested",
        "public_or_durable_effect_requested",
        "external_information_channel",
        "direct_qianxuesen_write_allowed"
      ],
      "properties": {
        "persistent_memory_write_requested": { "type": "boolean" },
        "skill_write_requested": { "type": "boolean" },
        "public_or_durable_effect_requested": { "type": "boolean" },
        "external_information_channel": { "type": "boolean" },
        "direct_qianxuesen_write_allowed": { "type": "boolean", "const": false }
      }
    },
    "control_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "reason", "replay_required", "tournament_required", "can_promote_now"],
      "properties": {
        "decision": { "type": "string" },
        "reason": { "type": "string" },
        "replay_required": { "type": "boolean" },
        "tournament_required": { "type": "boolean" },
        "can_promote_now": { "type": "boolean", "const": false }
      }
    },
    "research_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "digest_id",
        "source_event_ids",
        "topic",
        "channel",
        "observed_terms",
        "knowledge_gap_signals",
        "summary",
        "evolution_pressure",
        "candidate_policy"
      ],
      "properties": {
        "digest_id": { "type": "string" },
        "source_event_ids": { "$ref": "#/$defs/string_array" },
        "topic": { "type": "string" },
        "channel": { "type": "string" },
        "observed_terms": { "$ref": "#/$defs/string_array" },
        "knowledge_gap_signals": { "$ref": "#/$defs/string_array" },
        "summary": { "type": "string" },
        "evolution_pressure": { "type": "string" },
        "candidate_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "candidate_pool",
            "direct_memory_write",
            "direct_skill_write",
            "replay_or_tournament_required_before_promotion"
          ],
          "properties": {
            "candidate_pool": { "type": "string", "const": "research_digest" },
            "direct_memory_write": { "type": "boolean", "const": false },
            "direct_skill_write": { "type": "boolean", "const": false },
            "replay_or_tournament_required_before_promotion": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "evolution_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "source_event_ids",
        "candidate_type",
        "target_surface",
        "signal_origin",
        "interpretation",
        "confidence",
        "confidence_rule_id",
        "dedupe_cluster_key",
        "action_identity_fingerprint",
        "pressure_signals",
        "evidence_refs",
        "proposed_change",
        "expected_gain",
        "evidence_quality",
        "advisory_only",
        "evidence_reason_codes",
        "anomaly_rule_version",
        "anomaly_rule_ids",
        "raw_signal_count",
        "routing_stream",
        "stream_reason",
        "review_outcome",
        "status",
        "replay_required",
        "tournament_required",
        "can_promote_now",
        "promotion_gate"
      ],
      "properties": {
        "candidate_id": { "type": "string" },
        "source_event_ids": { "$ref": "#/$defs/string_array" },
        "candidate_type": { "type": "string" },
        "target_surface": {
          "type": "string",
          "enum": ["memory", "skill", "case", "policy", "damping", "ignore"]
        },
        "signal_origin": { "$ref": "#/$defs/signal_origin" },
        "interpretation": { "$ref": "#/$defs/interpretation" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "confidence_rule_id": { "type": "string" },
        "dedupe_cluster_key": { "type": "string" },
        "action_identity_fingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "pressure_signals": { "$ref": "#/$defs/string_array" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "proposed_change": { "type": "string" },
        "expected_gain": { "type": "string" },
        "evolution_evidence": { "$ref": "#/$defs/evolution_evidence" },
        "human_review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["route_target", "state", "consumer"],
          "properties": {
            "route_target": { "type": "string", "const": "policy" },
            "state": { "type": "string", "const": "policy_candidate_pending_human_review" },
            "consumer": { "type": "string", "const": "human_owner" }
          }
        },
        "evidence_quality": { "$ref": "#/$defs/evidence_quality" },
        "advisory_only": { "type": "boolean" },
        "evidence_reason_codes": { "$ref": "#/$defs/string_array" },
        "anomaly_rule_version": { "type": "string" },
        "anomaly_rule_ids": { "$ref": "#/$defs/string_array" },
        "raw_signal_count": { "type": "integer", "minimum": 1 },
        "routing_stream": { "$ref": "#/$defs/routing_stream" },
        "stream_reason": { "type": "string" },
        "review_outcome": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome",
            "dismissed_reason_code",
            "fire_count",
            "dismissal_rate",
            "human_action_rate",
            "noisy_rule"
          ],
          "properties": {
            "outcome": { "type": "string", "enum": ["pending", "actioned", "dismissed", "escalated"] },
            "dismissed_reason_code": { "type": ["string", "null"] },
            "fire_count": { "type": "integer", "minimum": 0 },
            "dismissal_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "human_action_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
            "noisy_rule": { "type": "boolean" }
          }
        },
        "status": { "type": "string", "enum": ["observed", "replay_required"] },
        "replay_required": { "type": "boolean" },
        "tournament_required": { "type": "boolean" },
        "can_promote_now": { "type": "boolean", "const": false },
        "promotion_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required_rules", "reason"],
          "properties": {
            "required_rules": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "reason": { "type": "string" }
          }
        }
      }
    },
    "observability_record": {
      "oneOf": [
        { "$ref": "#/$defs/evolution_candidate" },
        { "$ref": "#/$defs/action_history_monitor_record" }
      ],
      "allOf": [
        {
          "if": {
            "required": ["record_kind"],
            "properties": {
              "record_kind": { "const": "action_history_monitor" }
            }
          },
          "then": {
            "required": [
              "signal_origin",
              "routing_stream",
              "can_promote_now",
              "replay_required",
              "tournament_required"
            ],
            "properties": {
              "signal_origin": { "const": "runtime_operation_log" },
              "routing_stream": { "const": "observability_stream" },
              "can_promote_now": { "const": false },
              "replay_required": { "const": false },
              "tournament_required": { "const": false }
            }
          }
        }
      ]
    },
    "action_history_monitor_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "record_kind",
        "source_event_ids",
        "signal_origin",
        "interpretation",
        "routing_stream",
        "stream_reason",
        "status",
        "replay_required",
        "tournament_required",
        "can_promote_now",
        "advisory_only",
        "anomaly_rule_version",
        "anomaly_rule_ids",
        "metrics",
        "source_window"
      ],
      "properties": {
        "record_id": { "type": "string" },
        "record_kind": { "type": "string", "const": "action_history_monitor" },
        "source_event_ids": { "$ref": "#/$defs/string_array" },
        "signal_origin": { "type": "string", "const": "runtime_operation_log" },
        "interpretation": { "type": "string", "const": "adapter_inferred_evolution_pressure" },
        "routing_stream": { "type": "string", "const": "observability_stream" },
        "stream_reason": { "type": "string" },
        "status": { "type": "string", "const": "observed" },
        "replay_required": { "type": "boolean", "const": false },
        "tournament_required": { "type": "boolean", "const": false },
        "can_promote_now": { "type": "boolean", "const": false },
        "advisory_only": { "type": "boolean", "const": true },
        "anomaly_rule_version": { "type": "string", "const": "none" },
        "anomaly_rule_ids": {
          "type": "array",
          "maxItems": 0,
          "items": { "type": "string" }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["failure_after_repeat_rate", "query_entropy"],
          "properties": {
            "failure_after_repeat_rate": { "$ref": "#/$defs/action_history_failure_after_repeat_rate" },
            "query_entropy": { "$ref": "#/$defs/action_history_query_entropy" }
          }
        },
        "source_window": { "$ref": "#/$defs/source_window" }
      }
    },
    "action_history_metric_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "llm_api_calls"],
      "properties": {
        "kind": { "type": "string", "const": "deterministic_reducer" },
        "llm_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "action_history_failure_after_repeat_rate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "definition",
        "failure_definition",
        "source_contract",
        "numerator",
        "denominator",
        "value",
        "failed_source_event_ids",
        "repeated_source_event_ids",
        "status"
      ],
      "properties": {
        "metric_id": { "type": "string", "const": "failure_after_repeat_rate" },
        "definition": { "type": "string" },
        "failure_definition": { "type": "string", "const": "post_tool_call result returns error or failed" },
        "source_contract": { "$ref": "#/$defs/action_history_metric_contract" },
        "numerator": { "type": "integer", "minimum": 0 },
        "denominator": { "type": "integer", "minimum": 0 },
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "failed_source_event_ids": { "$ref": "#/$defs/string_array" },
        "repeated_source_event_ids": { "$ref": "#/$defs/string_array" },
        "status": {
          "type": "string",
          "enum": ["not_applicable", "repeat_after_failure_detected", "no_repeat_after_failure"]
        }
      }
    },
    "action_history_query_entropy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "definition",
        "query_source",
        "source_contract",
        "query_count",
        "unique_query_count",
        "entropy_bits",
        "normalized_entropy",
        "value",
        "query_tool_names",
        "source_event_ids",
        "status"
      ],
      "properties": {
        "metric_id": { "type": "string", "const": "query_entropy" },
        "definition": { "type": "string" },
        "query_source": { "type": "string", "const": "retrieval_or_search_tool_args_query" },
        "source_contract": { "$ref": "#/$defs/action_history_metric_contract" },
        "query_count": { "type": "integer", "minimum": 0 },
        "unique_query_count": { "type": "integer", "minimum": 0 },
        "entropy_bits": { "type": "number", "minimum": 0 },
        "normalized_entropy": { "type": "number", "minimum": 0, "maximum": 1 },
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "query_tool_names": { "$ref": "#/$defs/string_array" },
        "source_event_ids": { "$ref": "#/$defs/string_array" },
        "status": {
          "type": "string",
          "enum": ["insufficient_sample", "collapsed", "low_entropy", "diverse"]
        }
      }
    },
    "evolution_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "metric",
        "baseline_snapshot_id",
        "holdout_split_id",
        "eval_dataset_ref",
        "baseline_registered",
        "holdout_registered",
        "eval_dataset_registered",
        "before_score",
        "after_score",
        "delta",
        "sample_count",
        "metric_gaming_risk",
        "evidence_quality",
        "advisory_only",
        "reason_codes",
        "user_feedback_signal",
        "feedback_source",
        "llm_inferred",
        "feedback_usable_for_decision",
        "trace_ref",
        "redacted_trace_digest_ref",
        "trace_detail_source",
        "redaction_status",
        "raw_private_content_exported",
        "hermes_artifact_hash_before",
        "hermes_artifact_hash_after",
        "failure_refs",
        "evidence_refs",
        "positive_direction",
        "holdout_backed",
        "can_support_optimization"
      ],
      "properties": {
        "evidence_id": { "type": "string" },
        "metric": { "type": "string" },
        "baseline_snapshot_id": { "type": ["string", "null"] },
        "holdout_split_id": { "type": ["string", "null"] },
        "eval_dataset_ref": { "type": ["string", "null"] },
        "baseline_registered": { "type": "boolean" },
        "holdout_registered": { "type": "boolean" },
        "eval_dataset_registered": { "type": "boolean" },
        "before_score": { "type": ["number", "null"] },
        "after_score": { "type": ["number", "null"] },
        "delta": { "type": ["number", "null"] },
        "sample_count": { "type": "integer", "minimum": 0 },
        "metric_gaming_risk": {
          "type": "string",
          "enum": ["low", "medium", "high", "unknown"]
        },
        "evidence_quality": { "$ref": "#/$defs/evidence_quality" },
        "advisory_only": { "type": "boolean" },
        "reason_codes": { "$ref": "#/$defs/string_array" },
        "user_feedback_signal": {
          "type": ["string", "null"],
          "enum": ["correction", "accepted", "rejected", null]
        },
        "feedback_source": {
          "type": "string",
          "enum": ["user_explicit", "system_event", "trace_inferred"]
        },
        "llm_inferred": { "type": "boolean" },
        "feedback_usable_for_decision": { "type": "boolean" },
        "trace_ref": { "type": ["string", "null"] },
        "redacted_trace_digest_ref": { "type": ["string", "null"] },
        "trace_detail_source": {
          "type": "string",
          "enum": ["hermes_redacted_reducer_digest", "trace_identity_only"]
        },
        "redaction_status": { "type": "string", "const": "at_tap_point" },
        "raw_private_content_exported": { "type": "boolean", "const": false },
        "hermes_artifact_hash_before": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "hermes_artifact_hash_after": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "failure_refs": { "$ref": "#/$defs/string_array" },
        "evidence_refs": { "$ref": "#/$defs/string_array" },
        "positive_direction": { "type": "boolean" },
        "holdout_backed": { "type": "boolean" },
        "can_support_optimization": { "type": "boolean" }
      }
    },
    "plugin_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_id",
        "install_shape",
        "default_mode",
        "attach_points",
        "event_output",
        "no_direct_authority",
        "adapter_boundary"
      ],
      "properties": {
        "plugin_id": { "type": "string" },
        "install_shape": { "type": "string" },
        "default_mode": { "type": "string", "const": "observe_only" },
        "attach_points": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["hook", "purpose", "can_block_runtime", "default_action"],
            "properties": {
              "hook": { "type": "string" },
              "purpose": { "type": "string" },
              "can_block_runtime": { "type": "boolean" },
              "default_action": { "type": "string", "const": "observe" }
            }
          }
        },
        "event_output": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "format",
            "env_var",
            "default_path",
            "contains_raw_private_content",
            "redaction_status",
            "raw_private_content_exported"
          ],
          "properties": {
            "format": { "type": "string", "const": "ndjson" },
            "env_var": { "type": "string" },
            "default_path": { "type": "string" },
            "contains_raw_private_content": { "type": "boolean", "const": false },
            "redaction_status": { "type": "string", "const": "at_tap_point" },
            "raw_private_content_exported": { "type": "boolean", "const": false }
          }
        },
        "no_direct_authority": { "$ref": "#/$defs/string_array" },
        "adapter_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "universal_contract_stays_qianxuesen_owned",
            "framework_specific_code_required",
            "framework_specific_code_is_thin",
            "runtime_install_required_before_live_capture"
          ],
          "properties": {
            "universal_contract_stays_qianxuesen_owned": { "type": "boolean", "const": true },
            "framework_specific_code_required": { "type": "boolean", "const": true },
            "framework_specific_code_is_thin": { "type": "boolean", "const": true },
            "runtime_install_required_before_live_capture": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "control_plane_write_deny": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "default_decision",
        "allowed_surface",
        "direct_writes_allowed",
        "bypass_allowed",
        "applies_to",
        "enforced_by"
      ],
      "properties": {
        "policy_id": { "type": "string", "const": "misa.control_plane_write_deny.v1" },
        "default_decision": { "type": "string", "const": "deny" },
        "allowed_surface": { "type": "string", "const": "observe_and_emit_replay_required_candidates" },
        "direct_writes_allowed": { "type": "boolean", "const": false },
        "bypass_allowed": { "type": "boolean", "const": false },
        "applies_to": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "enforced_by": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_authority",
        "writes_persistent_memory",
        "writes_skills",
        "changes_route",
        "changes_winner",
        "blocks_runtime",
        "publication_allowed",
        "starts_services",
        "raw_private_content_persisted",
        "raw_private_content_exported",
        "llm_api_calls",
        "external_api_calls"
      ],
      "properties": {
        "production_authority": { "type": "boolean", "const": false },
        "writes_persistent_memory": { "type": "boolean", "const": false },
        "writes_skills": { "type": "boolean", "const": false },
        "changes_route": { "type": "boolean", "const": false },
        "changes_winner": { "type": "boolean", "const": false },
        "blocks_runtime": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "starts_services": { "type": "boolean", "const": false },
        "raw_private_content_persisted": { "type": "boolean", "const": false },
        "raw_private_content_exported": { "type": "boolean", "const": false },
        "llm_api_calls": { "type": "integer", "const": 0 },
        "external_api_calls": { "type": "integer", "const": 0 }
      }
    },
    "check": {
      "type": "object",
      "required": ["name", "ok"],
      "properties": {
        "name": { "type": "string" },
        "ok": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  }
}
